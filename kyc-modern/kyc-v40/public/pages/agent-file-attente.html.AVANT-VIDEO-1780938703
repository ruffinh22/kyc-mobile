</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
<div><div class="flex items-center justify-between mb-2"><h2 class="font-bold text-gray-800 uppercase text-sm">📥 En attente</h2><span class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-1 rounded-full" x-text="enAttente.length"></span></div><div class="space-y-2">
<template x-for="d in enAttente" :key="d.id"><div style="background:#fff;border:0.5px solid #d1d5db;border-left:4px solid #378add;border-radius:0;padding:12px 14px;width:100%;box-sizing:border-box" :class="(distributionMode==='auto'?'opacity-60 ':'')+(dureeMinutes(d.created_at)>5?'carte-urgente':'')">
