<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Autoriser cleartext HTTP pour développement/test local -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">10.208.9.116</domain>
    <domain includeSubdomains="true">10.58.134.116</domain>
    <domain includeSubdomains="true">10.0.0.0</domain>
    <domain includeSubdomains="true">192.168.0.0</domain>
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="true">127.0.0.1</domain>
  </domain-config>
  
  <!-- Production: tout en HTTPS -->
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="true">kyc.palladium-africa.com</domain>
  </domain-config>
</network-security-config>
