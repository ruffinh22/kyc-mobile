<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - File d'attente</title><script src="https://cdn.tailwindcss.com"></script><script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
<style>
body{font-family:'Inter',system-ui,sans-serif}
.sidebar{background:linear-gradient(180deg,#1A1A1A 0%,#2a2a2a 100%)}
.sb-link{display:flex;align-items:center;padding:.625rem .75rem;border-radius:.5rem;color:#d1d5db;transition:background .15s,color .15s;text-decoration:none}
.sb-link:hover{background:#374151;color:#fff}
.sb-link.active{background:#eab308;color:#111827;font-weight:600}
</style>
<script>
async function chargerSidebar(m){
  const t=sessionStorage.getItem('kyc_token');
  if(!t){window.location.href='/login';return}
  const r=await fetch('/static/pages/_sidebar.html');
  document.getElementById('sidebar-mount').innerHTML=await r.text();
  try{
    const u=JSON.parse(sessionStorage.getItem('kyc_user')||'{}');
    document.getElementById('sb-avatar').textContent=(u.matricule||'??').substring(0,2);
    document.getElementById('sb-nom').textContent=u.prenom||u.matricule||'';
    document.getElementById('sb-matricule').textContent=u.matricule||'';
    document.getElementById('sb-role').textContent=u.role||'';
  }catch(e){}
  if(m){const e=document.querySelector('[data-menu="'+m+'"]');if(e)e.classList.add('active')}
}
async function seDeconnecterGlobal(){
  const t=sessionStorage.getItem('kyc_token');
  if(t){try{await fetch('/api/auth/logout',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}}
  sessionStorage.clear();window.location.href='/login';
}
</script>
</head><body class="bg-gray-50 min-h-screen"><div class="flex min-h-screen"><div id="sidebar-mount"></div>
<main class="flex-1 p-6" x-data="fileAttente()" x-init="init()">
<div class="flex justify-between mb-6"><div><h1 class="text-2xl font-bold text-gray-800">📋 File d'attente</h1><p class="text-gray-500 text-sm">Mis à jour: <span x-text="derniereMaj"></span></p></div><div class="flex gap-2"><button @click="demanderAide()" :disabled="actionEnCours" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-semibold">🆘 Aide</button><button @click="togglePause()" class="px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white rounded-lg font-semibold">⏸️ Pause</button><button @click="charger()" class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">🔄 Rafraîchir</button></div></div>
<div x-show="dossiersAttenteVieux>0" class="bg-red-500 text-white text-center py-2 mb-4 rounded">⚠️ <span x-text="dossiersAttenteVieux"></span> dossier(s) en attente > 5 min !</div>
<div class="grid grid-cols-6 gap-2 mb-3">
<div class="bg-white rounded-lg border border-orange-200 p-2 text-center"><div class="text-xl font-bold text-orange-600" x-text="stats.en_attente">0</div><div class="text-xs font-semibold text-gray-500 uppercase">En attente</div></div>
<div class="bg-white rounded-lg border border-yellow-200 p-2 text-center"><div class="text-xl font-bold text-yellow-600" x-text="stats.total">0</div><div class="text-xs font-semibold text-gray-500 uppercase">Total</div></div>
<div class="bg-white rounded-lg border border-blue-200 p-2 text-center"><div class="text-xl font-bold text-blue-600" x-text="stats.en_cours">0</div><div class="text-xs font-semibold text-gray-500 uppercase">En cours</div></div>
<div class="bg-white rounded-lg border border-green-200 p-2 text-center"><div class="text-xl font-bold text-green-600" x-text="stats.accepte">0</div><div class="text-xs font-semibold text-gray-500 uppercase">Acceptés</div></div>
<div class="bg-white rounded-lg border border-red-200 p-2 text-center"><div class="text-xl font-bold text-red-600" x-text="stats.rejete">0</div><div class="text-xs font-semibold text-gray-500 uppercase">Rejetés</div></div>
<div class="bg-white rounded-lg border border-purple-200 p-2 text-center"><div class="text-xl font-bold text-purple-600" x-text="tempsMoyenTraitement()+' min'">0</div><div class="text-xs font-semibold text-gray-500 uppercase">Tps moyen</div></div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
<div><div class="flex items-center justify-between mb-2"><h2 class="font-bold text-gray-800 uppercase text-sm">📥 En attente</h2><span class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-1 rounded-full" x-text="enAttente.length"></span></div><div class="space-y-2">
<template x-for="d in enAttente" :key="d.id"><div class="bg-white border-l-4 border-orange-400 rounded-lg shadow-sm p-2.5" style="width:100%;min-height:120px;box-sizing:border-box" :class="distributionMode==='auto'?'opacity-50':''"><div class="flex justify-between mb-1"><div><p class="text-sm text-gray-500 italic">🔒 N° masqué</p><p class="text-xs text-gray-400 font-mono" x-text="d.id"></p></div><span class="bg-orange-100 text-orange-800 text-xs px-2 py-1 rounded">en_attente</span></div><div class="text-xs text-gray-600 mb-2"><p>📅 <span x-text="d.heure_reception"></span> • <span :class="dureeMinutes(d.created_at)>5?'text-red-600 font-semibold':''" x-text="dureeMinutes(d.created_at)+' min'"></span></p><p class="text-gray-400 italic">🔒 Informations et captures masquées</p></div><button x-show="distributionMode==='manuel'" @click="prendre(d.id)" :disabled="actionEnCours" class="w-full bg-yellow-500 hover:bg-yellow-600 disabled:bg-gray-300 text-white font-semibold py-1.5 rounded text-sm">👉 Prendre</button></div></template>
<div x-show="enAttente.length===0" class="text-center py-4 text-gray-400 text-sm">📭 Aucun dossier en attente</div>
</div></div>
<div><div class="flex items-center justify-between mb-2"><h2 class="font-bold text-gray-800 uppercase text-sm">⚡ En cours</h2><span class="bg-blue-100 text-blue-800 text-xs font-bold px-2 py-1 rounded-full" x-text="enCours.length"></span></div><div class="space-y-2"><button x-show="distributionMode==='auto'&&enCours.length===1" @click="appeler()" :disabled="actionEnCours" class="w-full bg-blue-600 hover:bg-blue-700 disabled:bg-gray-300 text-white font-semibold py-2 rounded-lg mb-2 text-sm">📞 Appeler un dossier</button>
<template x-for="d in enCours" :key="d.id"><div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3" style="width:100%;box-sizing:border-box">
<div class="flex justify-between items-start mb-2"><p class="font-bold text-lg text-gray-900" x-text="d.numero_mtn"></p><p class="text-xs text-gray-400 font-mono" x-text="d.id"></p></div>
<div class="flex gap-1.5 mb-3">
<div class="flex-1 text-center"><div class="bg-gray-100 rounded border border-gray-200 overflow-hidden flex items-center justify-center" style="height:64px"><img x-show="photosUrls[d.id]&&photosUrls[d.id].recto" :src="photosUrls[d.id]?photosUrls[d.id].recto:''" @click="agrandir(photosUrls[d.id]&&photosUrls[d.id].recto)" class="w-full h-full object-cover cursor-pointer"><span x-show="!(photosUrls[d.id]&&photosUrls[d.id].recto)" class="text-gray-300 text-[10px]">Recto CNI</span></div></div>
<div class="flex-1 text-center"><div class="bg-gray-100 rounded border border-gray-200 overflow-hidden flex items-center justify-center" style="height:64px"><img x-show="photosUrls[d.id]&&photosUrls[d.id].verso" :src="photosUrls[d.id]?photosUrls[d.id].verso:''" @click="agrandir(photosUrls[d.id]&&photosUrls[d.id].verso)" class="w-full h-full object-cover cursor-pointer"><span x-show="!(photosUrls[d.id]&&photosUrls[d.id].verso)" class="text-gray-300 text-[10px]">Verso CNI</span></div></div>
<div class="flex-1 text-center"><div class="bg-gray-100 rounded border border-gray-200 overflow-hidden flex items-center justify-center" style="height:64px"><img x-show="photosUrls[d.id]&&photosUrls[d.id].live" :src="photosUrls[d.id]?photosUrls[d.id].live:''" @click="agrandir(photosUrls[d.id]&&photosUrls[d.id].live)" class="w-full h-full object-cover cursor-pointer"><span x-show="!(photosUrls[d.id]&&photosUrls[d.id].live)" class="text-gray-300 text-[10px]">Photo live</span></div></div>
</div>
<div class="mb-2"><p class="text-[11px] font-bold text-gray-500 uppercase mb-0.5">Numero MTN webcare</p><div class="flex items-center gap-2"><span class="font-bold text-base text-gray-900" x-text="d.numero_mtn"></span><button @click="copier(d.numero_mtn)" class="text-xs text-gray-500 border border-gray-300 rounded px-2 py-0.5 hover:bg-gray-50">Copier</button></div></div>
<div class="mb-2"><p class="text-[11px] font-bold text-gray-500 uppercase mb-0.5">Heure</p><p class="text-sm text-gray-700" x-text="d.heure_prise||d.heure_reception||'?'"></p></div>
<div class="mb-3" x-show="d.wa_agent"><p class="text-[11px] font-bold text-gray-500 uppercase mb-0.5">Agent acquisition</p><div class="flex items-center gap-2"><span style="color:#25D366;font-size:16px">&#9990;</span><span class="font-bold text-base text-gray-900" x-text="d.wa_agent"></span><button @click="copier(d.wa_agent)" class="text-xs text-gray-500 border border-gray-300 rounded px-2 py-0.5 hover:bg-gray-50">Copier</button></div></div>
<div class="grid grid-cols-2 gap-2"><button @click="accepter(d.id)" :disabled="actionEnCours" class="bg-green-500 hover:bg-green-600 disabled:bg-gray-300 text-white font-semibold py-2 rounded text-sm">Accepter</button><button @click="ouvrirRejet(d)" :disabled="actionEnCours" class="bg-red-500 hover:bg-red-600 disabled:bg-gray-300 text-white font-semibold py-2 rounded text-sm">Rejeter</button></div>
</div></template>
<div x-show="enCours.length===0" class="text-center py-4 text-gray-400 text-sm">💤 Aucun dossier en cours</div>
</div></div>
</div>
<div x-show="modalRejet.ouvert" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"><div class="bg-white rounded-2xl p-6 max-w-md w-full"><h3 class="text-xl font-bold mb-4">❌ Rejeter</h3><p class="text-sm text-gray-600 mb-2">Numéro: <strong x-text="modalRejet.numero"></strong></p><label class="block text-sm font-semibold mt-4 mb-2">Motif *</label><textarea x-model="modalRejet.raison" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg"></textarea><div class="flex gap-2 mt-6"><button @click="fermerRejet()" class="flex-1 py-2 border border-gray-300 rounded-lg">Annuler</button><button @click="confirmerRejet()" :disabled="!modalRejet.raison||modalRejet.raison.length<3" class="flex-1 py-2 bg-red-500 hover:bg-red-600 disabled:bg-gray-300 text-white font-semibold rounded-lg">Confirmer</button></div></div></div>
<div x-show="modalAccept.ouvert" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"><div class="bg-white rounded-2xl p-6 max-w-md w-full"><h3 class="text-xl font-bold mb-4">✅ Accepter</h3><p class="text-sm text-gray-600 mb-2">Numéro: <strong x-text="modalAccept.numero"></strong></p><p class="text-sm text-gray-600 mt-2">Confirmer l'acceptation de ce dossier ?</p><div class="flex gap-2 mt-6"><button @click="fermerAccept()" class="flex-1 py-2 border border-gray-300 rounded-lg">Annuler</button><button @click="confirmerAccept()" class="flex-1 py-2 bg-green-500 hover:bg-green-600 disabled:bg-gray-300 text-white font-semibold rounded-lg">Confirmer</button></div></div></div>
<div x-show="modalPause.ouvert" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"><div class="bg-white rounded-2xl p-6 max-w-md w-full"><h3 class="text-xl font-bold mb-4">⏸️ Passer en pause</h3><p class="text-sm text-gray-600 mt-2">Vos dossiers en cours vont repartir dans la file. Confirmer la pause ?</p><div class="flex gap-2 mt-6"><button @click="modalPause.ouvert=false" class="flex-1 py-2 border border-gray-300 rounded-lg">Annuler</button><button @click="confirmerPause()" class="flex-1 py-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold rounded-lg">Confirmer</button></div></div></div>
<!-- Lightbox capture -->
<div x-show="lightbox" @click="lightbox=''" class="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50 p-4 cursor-zoom-out"><img :src="lightbox" class="max-h-full max-w-full rounded-lg shadow-2xl"></div>
<div x-show="toast.message" class="fixed bottom-4 right-4 px-6 py-3 rounded-lg shadow-lg text-white font-semibold z-50" :class="toast.type==='success'?'bg-green-500':'bg-red-500'"><span x-text="toast.message"></span></div>
<div x-show="enPause" class="fixed inset-0 z-[100] bg-gradient-to-br from-amber-600 to-amber-800 flex items-center justify-center" style="display:none">
  <div class="text-center text-white px-6">
    <div class="text-6xl mb-4">⏸️</div>
    <h1 class="text-4xl font-bold mb-2">EN PAUSE</h1>
    <p class="text-2xl mb-6" x-text="user.prenom?(user.prenom+' '+(user.nom||'')):(user.matricule||'')"></p>
    <div class="bg-white/20 rounded-2xl p-6 mb-6 inline-block">
      <p class="text-sm uppercase tracking-wide opacity-80">Durée de la pause</p>
      <p class="text-5xl font-mono font-bold my-2" x-text="chronoPause"></p>
    </div>
    <div class="flex gap-6 justify-center mb-8 text-lg">
      <div><span class="opacity-80">Pauses aujourd'hui :</span> <strong x-text="resumePauses.nb"></strong></div>
      <div><span class="opacity-80">Temps total :</span> <strong x-text="resumePauses.total"></strong></div>
    </div>
    <button @click="togglePause()" class="px-10 py-4 bg-white text-amber-700 hover:bg-gray-100 rounded-xl text-xl font-bold shadow-lg">▶️ Reprendre le travail</button>
  </div>
</div>
</main></div>
<script>
function fileAttente(){
  return {
    user:{},
    stats:{total:0,en_attente:0,en_cours:0,accepte:0,rejete:0},
    enAttente:[],
    distributionMode:'manuel',
    enPause:false,
    chronoPause:'00:00',
    chronoTimer:null,
    pauseDebut:null,
    resumePauses:{nb:0,total:'0 min'},
    enCours:[],
    tousDossiers:[],
    photosUrls:{},
    lightbox:'',
    loading:false,
    actionEnCours:false,
    derniereMaj:'',
    dossiersAttenteVieux:0,
    modalRejet:{ouvert:false,id:null,numero:'',raison:''},
    modalAccept:{ouvert:false,id:null,numero:''},
    modalPause:{ouvert:false},
    toast:{message:'',type:'success',timer:null},
    pollingTimer:null,
    async init(){
      await chargerSidebar('file-attente');
      try{const t=sessionStorage.getItem('kyc_token');const rm=await fetch('/api/config/distribution-mode',{headers:{'Authorization':'Bearer '+t}});if(rm.ok){const dm=await rm.json();this.distributionMode=dm.mode||'manuel'}}catch(e){console.error('mode',e)}
      try{this.user=JSON.parse(sessionStorage.getItem('kyc_user')||'{}')}catch(e){}
      await this.charger();
      this.pollingTimer=setInterval(()=>this.charger(true),15000);
      this.pingDispo();
      this.pingTimer=setInterval(()=>this.pingDispo(),10000);
      this.demarrerFlux();
    },
    async charger(silencieux){
      if(!silencieux)this.loading=true;
      const t=sessionStorage.getItem('kyc_token');
      const d=new Date().toISOString().slice(0,10);
      try{
        const r1=await fetch('/api/dossiers/stats?date='+d,{headers:{'Authorization':'Bearer '+t}});
        if(r1.status===401){window.location.href='/login';return}
        this.stats=await r1.json();
        const r2=await fetch('/api/dossiers',{headers:{'Authorization':'Bearer '+t}});
        const dat=await r2.json();
        const tous=dat.dossiers||[];
        this.tousDossiers=tous;
        this.enAttente=tous.filter(d=>d.statut==='en_attente').sort((a,b)=>a.created_at-b.created_at);
        this.enCours=tous.filter(d=>d.statut==='en_cours'&&d.agent_saisie===this.user.matricule);
        this.dossiersAttenteVieux=this.enAttente.filter(d=>this.dureeMinutes(d.created_at)>5).length;
        this.derniereMaj=new Date().toLocaleTimeString('fr-FR');
        await this.chargerPhotosEnCours();
      }catch(e){console.error(e)}finally{this.loading=false}
    },
    async chargerPhotosEnCours(){
      const t=sessionStorage.getItem('kyc_token');
      const nouveaux={};
      for(const d of this.enCours){
        // Si on a déjà chargé les photos de ce dossier, on les réutilise (évite de recharger à chaque polling)
        if(this.photosUrls[d.id]){nouveaux[d.id]=this.photosUrls[d.id];continue}
        const p={recto:null,verso:null,live:null};
        for(const type of ['recto','verso','live']){
          try{
            const r=await fetch('/api/dossiers/'+d.id+'/photo/'+type,{headers:{'Authorization':'Bearer '+t}});
            if(r.ok){const b=await r.blob();p[type]=URL.createObjectURL(b)}
          }catch(e){}
        }
        nouveaux[d.id]=p;
      }
      // Libère les URLs des dossiers qui ne sont plus en cours
      for(const id in this.photosUrls){
        if(!nouveaux[id]){
          const p=this.photosUrls[id];
          ['recto','verso','live'].forEach(k=>{if(p&&p[k])URL.revokeObjectURL(p[k])});
        }
      }
      this.photosUrls=nouveaux;
    },
    agrandir(url){if(url)this.lightbox=url},
    tempsMoyenTraitement(){
      // Moyenne (en minutes) entre prise (assigne_le) et cloture (closed_at)
      // des dossiers traites aujourd'hui par cet agent.
      const traites=(this.tousDossiers||[]).filter(d=>
        (d.statut==='accepte'||d.statut==='rejete') &&
        d.agent_saisie===this.user.matricule &&
        d.assigne_le && d.closed_at && d.closed_at>=d.assigne_le
      );
      if(!traites.length) return 0;
      let total=0;
      for(const d of traites){ total += (d.closed_at - d.assigne_le); }
      return Math.round((total/traites.length)/60);
    },
    dureeMinutes(ts){return Math.floor((Math.floor(Date.now()/1000)-ts)/60)},
    demarrerFlux(){
      const t=sessionStorage.getItem('kyc_token');
      if(!t)return;
      try{
        if(this.flux){this.flux.close()}
        this.flux=new EventSource('/api/dossiers/flux?token='+encodeURIComponent(t));
        this.flux.addEventListener('nouveau-dossier',()=>{ this.charger(true); });
        this.flux.onerror=()=>{ /* reconnexion auto par le navigateur */ };
      }catch(e){console.error('flux SSE',e)}
    },
    fmtDuree(sec){const m=Math.floor(sec/60),s2=sec%60;return String(m).padStart(2,'0')+':'+String(s2).padStart(2,'0')},
    async chargerResumePauses(){
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/pauses-jour',{headers:{'Authorization':'Bearer '+t}});
        if(r.ok){const d=await r.json();this.resumePauses={nb:d.nb_pauses,total:Math.round(d.duree_totale_sec/60)+' min'};if(d.pause_debut)this.pauseDebut=d.pause_debut}
      }catch(e){}
    },
    demarrerChrono(){
      if(this.chronoTimer)clearInterval(this.chronoTimer);
      const maj=()=>{ if(!this.pauseDebut){this.chronoPause='00:00';return} const ecoule=Math.floor(Date.now()/1000)-this.pauseDebut; this.chronoPause=this.fmtDuree(ecoule); };
      maj();
      this.chronoTimer=setInterval(maj,1000);
    },
    async demanderAide(){
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/aide',{method:'POST',headers:{'Authorization':'Bearer '+t}});
        if(r.ok){this.afficherToast('Demande d\'aide envoyee au superviseur','success')}
        else{this.afficherToast('Erreur lors de l\'envoi','error')}
      }catch(e){this.afficherToast('Erreur reseau','error')}
    },
    async togglePause(){
      // Si on veut passer en pause -> ouvrir la modale de confirmation
      if(!this.enPause){ this.modalPause.ouvert=true; return; }
      // Sinon (reprise) -> agir directement
      await this.confirmerPause();
    },
    async confirmerPause(){
      this.modalPause.ouvert=false;
      const t=sessionStorage.getItem('kyc_token');
      const action=this.enPause?'reprendre':'pause';
      try{
        const r=await fetch('/api/dossiers/pause',{method:'POST',headers:{'Authorization':'Bearer '+t,'Content-Type':'application/json'},body:JSON.stringify({action})});
        const d=await r.json().catch(()=>({}));
        if(r.ok){
          this.enPause=(d.statut==='pause');
          if(this.enPause){ this.pauseDebut=Math.floor(Date.now()/1000); await this.chargerResumePauses(); this.demarrerChrono(); }
          else { if(this.chronoTimer){clearInterval(this.chronoTimer);this.chronoTimer=null} this.pauseDebut=null; }
          this.afficherToast(this.enPause?'En pause':'Vous avez repris','success');
          await this.charger();
        } else { this.afficherToast(d.error||'Erreur','error'); }
      }catch(e){this.afficherToast('Erreur reseau','error')}
    },
    async pingDispo(){
      const t=sessionStorage.getItem('kyc_token');
      try{await fetch('/api/dossiers/ping-dispo',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}
    },
    async appeler(){
      if(this.actionEnCours)return;
      this.actionEnCours=true;
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/appeler',{method:'POST',headers:{'Authorization':'Bearer '+t}});
        const d=await r.json().catch(()=>({}));
        if(r.ok&&d.aucun){this.afficherToast('Aucun dossier en attente','error')}
        else if(r.ok){this.afficherToast('Dossier attribue','success');await this.charger()}
        else{this.afficherToast(d.error||'Erreur','error')}
      }catch(e){this.afficherToast('Erreur reseau','error')}
      finally{this.actionEnCours=false}
    },
    async prendre(id){
      if(this.actionEnCours)return;
      this.actionEnCours=true;
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/'+id+'/prendre',{method:'POST',headers:{'Authorization':'Bearer '+t}});
        const dat=await r.json();
        if(r.ok){this.afficherToast('Dossier pris','success');await this.charger()}
        else{this.afficherToast(dat.error||'Erreur','error')}
      }catch(e){this.afficherToast('Erreur réseau','error')}finally{this.actionEnCours=false}
    },
    accepter(id){
      const dd=this.enCours.find(x=>x.id===id);
      this.modalAccept={ouvert:true,id:id,numero:dd?dd.numero_mtn:''};
    },
    fermerAccept(){this.modalAccept.ouvert=false;},
    async confirmerAccept(){
      const id=this.modalAccept.id;
      this.modalAccept.ouvert=false;
      if(this.actionEnCours)return;
      this.actionEnCours=true;
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/'+id+'/accepter',{method:'POST',headers:{'Authorization':'Bearer '+t,'Content-Type':'application/json'},body:'{}'});
        const dat=await r.json();
        if(r.ok){const dd=this.enCours.find(x=>x.id===id);const num=dd?dd.numero_mtn:'';this.afficherToast('✅ Accepté - GSM à remplir','success');setTimeout(()=>{window.location.href='/agent/gross-add?numero='+encodeURIComponent(num||'')+'&dossier='+encodeURIComponent(id)},800);return}
        else{this.afficherToast(dat.error||'Erreur','error')}
      }catch(e){this.afficherToast('Erreur réseau','error')}finally{this.actionEnCours=false}
    },
    ouvrirRejet(d){this.modalRejet={ouvert:true,id:d.id,numero:d.numero_mtn,raison:''}},
    fermerRejet(){this.modalRejet.ouvert=false},
    async confirmerRejet(){
      if(!this.modalRejet.raison||this.modalRejet.raison.length<3)return;
      this.actionEnCours=true;
      const t=sessionStorage.getItem('kyc_token');
      const id=this.modalRejet.id;
      try{
        const r=await fetch('/api/dossiers/'+id+'/rejeter',{method:'POST',headers:{'Authorization':'Bearer '+t,'Content-Type':'application/json'},body:JSON.stringify({raison_rejet:this.modalRejet.raison})});
        const dat=await r.json();
        if(r.ok){const num=this.modalRejet.numero;this.afficherToast('❌ Rejeté - GSM à remplir','success');this.fermerRejet();setTimeout(()=>{window.location.href='/agent/gross-add?numero='+encodeURIComponent(num||'')+'&dossier='+encodeURIComponent(id)},800);return}
        else{this.afficherToast(dat.error||'Erreur','error')}
      }catch(e){this.afficherToast('Erreur','error')}finally{this.actionEnCours=false}
    },
    afficherToast(m,t){
      this.toast.message=m;this.toast.type=t||'success';
      if(this.toast.timer)clearTimeout(this.toast.timer);
      this.toast.timer=setTimeout(()=>{this.toast.message=''},3000);
    }
  };
}
</script>
</body></html>
