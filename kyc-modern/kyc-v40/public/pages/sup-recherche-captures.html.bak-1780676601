<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - Recherche captures</title><script src="https://cdn.tailwindcss.com"></script>
<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head><body class="bg-gray-100 min-h-screen"><div class="flex min-h-screen"><div id="sidebar-mount" class="w-64 flex-shrink-0"></div>
<main class="flex-1 min-w-0 p-6" x-data="rechCaptures()" x-init="init()" style="background:#f3f4f6">
<div style="margin-bottom:20px">
<h1 style="font-size:24px;font-weight:800;color:#1f2937;margin:0">Recherche captures</h1>
<p style="color:#9ca3af;font-size:14px;margin:2px 0 0">Rechercher un numero pour voir les captures inserees lors du traitement</p>
</div>
<div style="background:#fff;border:1px solid #e8e8ec;border-radius:14px;padding:16px;margin-bottom:18px;display:flex;gap:10px;align-items:center">
<input type="text" x-model="numero" @keydown.enter="rechercher()" placeholder="Entrez un numero (ex: 064055555)" style="flex:1;padding:10px 12px;border:1px solid #d1d5db;border-radius:10px;font-size:14px">
<button @click="rechercher()" :disabled="loading" style="background:#7f1d1d;color:#fff;font-weight:700;padding:10px 20px;border:none;border-radius:10px;cursor:pointer" x-text="loading?'Recherche...':'Rechercher'"></button>
</div>
<div x-show="cherche && resultats.length===0 && !loading" style="color:#9ca3af;font-size:14px;text-align:center;padding:30px">Aucune capture trouvee pour ce numero.</div>
<template x-for="r in resultats" :key="r.id">
<div style="background:#fff;border:1px solid #e8e8ec;border-radius:14px;padding:18px;margin-bottom:14px">
  <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:14px">
    <div>
      <span style="font-size:18px;font-weight:800;color:#1f2937" x-text="r.numero"></span>
      <span x-show="r.nom_client" style="font-size:14px;color:#6b7280;margin-left:8px" x-text="r.nom_client"></span>
    </div>
    <div style="font-size:12px;color:#9ca3af;text-align:right">
      <span x-text="r.date_saisie"></span> <span x-text="r.heure_saisie"></span><br>
      Agent: <span x-text="r.agent_ctrl||'—'"></span> &nbsp;·&nbsp; Coach: <span x-text="r.coach||'—'"></span>
    </div>
  </div>
  <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;font-size:12px">
    <span style="background:#f1f5f9;color:#475569;padding:3px 10px;border-radius:6px" x-show="r.constat">Constat: <span x-text="r.constat"></span></span>
    <span style="background:#f1f5f9;color:#475569;padding:3px 10px;border-radius:6px" x-show="r.action">Action: <span x-text="r.action"></span></span>
    <span style="background:#f1f5f9;color:#475569;padding:3px 10px;border-radius:6px" x-show="r.statut_final">Statut: <span x-text="r.statut_final"></span></span>
    <span style="background:#f1f5f9;color:#475569;padding:3px 10px;border-radius:6px" x-show="r.traitement">Traitement: <span x-text="r.traitement"></span></span>
  </div>
  <div style="display:flex;gap:12px;flex-wrap:wrap">
    <template x-for="cap in capList(r)" :key="cap.url">
      <div style="text-align:center">
        <a :href="cap.url" target="_blank"><img :src="cap.url" style="width:160px;height:120px;object-fit:cover;border:1px solid #e5e7eb;border-radius:10px;cursor:pointer" loading="lazy"></a>
        <p style="font-size:11px;color:#9ca3af;margin:4px 0 0" x-text="cap.label"></p>
      </div>
    </template>
    <span x-show="capList(r).length===0" style="font-size:12px;color:#9ca3af;font-style:italic">Aucune capture pour cette saisie</span>
  </div>
</div>
</template>
</main></div>
<script>
function rechCaptures(){
  return {
    numero:'', loading:false, cherche:false, resultats:[],
    token(){ return sessionStorage.getItem('kyc_token')||''; },
    async init(){
      const sb = location.pathname.startsWith('/sup') ? '_sidebar-sup.html' : '_sidebar-admin.html';
      try{
        const r=await fetch('/static/pages/'+sb);
        if(r.ok){ document.getElementById('sidebar-mount').innerHTML=await r.text(); }
      }catch(e){}
    },
    capList(r){
      const out=[];
      const add=(v,lbl)=>{ if(v) out.push({url:'/api/gsm/captures/'+v, label:lbl}); };
      add(r.capture_a,'Avant'); add(r.capture_p,'Pendant'); add(r.capture_aa,'Apres');
      return out;
    },
    async rechercher(){
      const n=(this.numero||'').trim();
      if(n.length<3){ return; }
      this.loading=true; this.cherche=true;
      try{
        const r=await fetch('/api/gsm/recherche?numero='+encodeURIComponent(n),{headers:{'Authorization':'Bearer '+this.token()}});
        if(r.ok){ const d=await r.json(); this.resultats=d.resultats||[]; }
        else { this.resultats=[]; }
      }catch(e){ this.resultats=[]; }
      this.loading=false;
    }
  };
}
</script>
</body></html>
