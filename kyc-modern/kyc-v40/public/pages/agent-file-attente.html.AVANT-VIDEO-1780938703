<div class="bg-gray-100 rounded-lg border border-gray-200 overflow-hidden flex items-center justify-center" style="width:48px;height:48px;flex:none"><img x-show="photosUrls[d.id]&&photosUrls[d.id].live" :src="photosUrls[d.id]?photosUrls[d.id].live:''" @click="agrandir(photosUrls[d.id]&&photosUrls[d.id].live)" class="w-full h-full object-cover cursor-pointer"><span x-show="!(photosUrls[d.id]&&photosUrls[d.id].live)" class="text-gray-300" style="font-size:8px">Live</span></div>
</div><div class="text-right"><p class="text-xs text-gray-400 font-mono" x-text="d.id"></p><p class="text-xs text-gray-500 mt-0.5">Heure: <span class="font-semibold" x-text="d.heure_prise||d.heure_reception||'?'"></span></p></div></div>

<div class="flex gap-3 mb-2">
<div class="flex-1"><p class="text-[11px] font-bold text-gray-500 uppercase mb-0.5">Numero MTN webcare</p><div class="flex items-center gap-1.5"><span class="font-bold text-sm text-gray-900" x-text="d.numero_mtn"></span><button @click="copier(d.numero_mtn)" class="text-[11px] text-gray-500 border border-gray-300 rounded px-1.5 py-0.5 hover:bg-gray-50">Copier</button></div></div>
