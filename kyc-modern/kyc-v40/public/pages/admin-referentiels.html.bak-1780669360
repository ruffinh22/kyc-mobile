<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - Referentiels GSM</title><script src="https://cdn.tailwindcss.com"></script>
<style>
body{font-family:Inter,system-ui,sans-serif}
.sidebar{background:linear-gradient(180deg,#7f1d1d 0%,#991b1b 100%)}
.sb-link{display:flex;align-items:center;padding:.625rem .75rem;border-radius:.5rem;color:#cbd5e1;transition:background .15s,color .15s;text-decoration:none}
.sb-link:hover{background:#1e293b;color:#fff}
.sb-link.active{background:#3b82f6;color:#fff;font-weight:600}
.ref-card{background:#fff;border:1px solid #e8e8ec;border-radius:14px;padding:18px;margin-bottom:16px}
.ref-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.ref-input{flex:1;padding:8px 10px;border:1px solid #d1d5db;border-radius:8px;font-size:13px}
.ref-btn{border:none;border-radius:8px;cursor:pointer;font-size:13px;padding:7px 10px}
.ref-icon{width:32px;height:32px;display:inline-flex;align-items:center;justify-content:center;border:1px solid #d1d5db;border-radius:8px;background:#fff;cursor:pointer;font-size:14px;color:#475569}
.ref-icon:hover{background:#f3f4f6}
.ref-icon:disabled{opacity:.4;cursor:not-allowed}
</style>
<script>
async function chargerSidebarAdm(m){
  const t=sessionStorage.getItem('kyc_token');
  if(!t){window.location.href='/login';return}
  const u=JSON.parse(sessionStorage.getItem('kyc_user')||'{}');
  const r=await fetch('/static/pages/_sidebar-admin.html');
  document.getElementById('sidebar-mount').innerHTML=await r.text();
  try{
    document.getElementById('sb-avatar').textContent=(u.matricule||'??').substring(0,2);
    document.getElementById('sb-nom').textContent=u.prenom||u.matricule||'';
    document.getElementById('sb-matricule').textContent=u.matricule||'';
    document.getElementById('sb-role').textContent=u.role||'';
  }catch(e){}
  if(m){const e=document.querySelector('[data-menu="'+m+'"]');if(e)e.classList.add('active')}
}
async function seDeconnecterGlobal(){
  const t=sessionStorage.getItem('kyc_token');
  if(t){try{await fetch('/api/auth/logout',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}}
  sessionStorage.clear();window.location.href='/login';
}
</script>
<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head><body data-antiflash="1" style="background:linear-gradient(180deg,#7f1d1d 0%,#991b1b 100%)" class="bg-gray-100 min-h-screen"><div class="flex min-h-screen"><div id="sidebar-mount" class="w-64 flex-shrink-0" style="background:linear-gradient(180deg,#7f1d1d 0%,#991b1b 100%);min-height:100vh"></div>
<main class="flex-1 min-w-0 p-6" x-data="refsAdmin()" x-init="init()" style="background:#f3f4f6">
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
<div><h1 style="font-size:24px;font-weight:800;color:#1f2937;margin:0">Referentiels GSM</h1>
<p style="color:#9ca3af;font-size:14px;margin:2px 0 0">Gerer les listes de valeurs des menus deroulants de la saisie GSM</p></div>
<div style="display:flex;gap:10px;align-items:center">
<span x-show="msg" x-text="msg" :style="msgType==='ok'?'color:#15803d':'color:#b91c1c'" style="font-size:13px;font-weight:600"></span>
<button @click="enregistrer()" :disabled="loading" class="ref-btn" style="background:#7f1d1d;color:#fff;font-weight:700;padding:10px 18px" x-text="loading?'Enregistrement...':'Enregistrer'"></button>
</div>
</div>
<div x-show="!chargee" style="color:#9ca3af;font-size:14px">Chargement...</div>
<template x-for="champ in champs" :key="champ.cle">
<div class="ref-card" x-show="chargee">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
    <h2 style="font-size:16px;font-weight:700;color:#1f2937;margin:0" x-text="champ.label"></h2>
    <span style="font-size:12px;color:#9ca3af" x-text="(data[champ.cle]||[]).length + ' valeur(s)'"></span>
  </div>
  <template x-for="(val,idx) in (data[champ.cle]||[])" :key="idx">
    <div class="ref-row">
      <input type="text" class="ref-input" :value="val" @input="data[champ.cle][idx]=$event.target.value">
      <button class="ref-icon" @click="monter(champ.cle,idx)" :disabled="idx===0" title="Monter">&#9650;</button>
      <button class="ref-icon" @click="descendre(champ.cle,idx)" :disabled="idx===(data[champ.cle].length-1)" title="Descendre">&#9660;</button>
      <button class="ref-icon" @click="supprimer(champ.cle,idx)" title="Supprimer" style="color:#b91c1c;border-color:#fca5a5">&#10005;</button>
    </div>
  </template>
  <div class="ref-row" style="margin-top:10px">
    <input type="text" class="ref-input" :placeholder="'Ajouter une valeur a ' + champ.label" x-model="nouveau[champ.cle]" @keydown.enter="ajouter(champ.cle)">
    <button class="ref-btn" @click="ajouter(champ.cle)" style="background:#16a34a;color:#fff;font-weight:600;padding:8px 14px">+ Ajouter</button>
  </div>
</div>
</template>
</main></div>
<script>
function refsAdmin(){
  return {
    chargee:false, loading:false, msg:'', msgType:'ok', data:{}, nouveau:{},
    champs:[
      {cle:'constat',label:'Constat'},
      {cle:'piece',label:'Piece'},
      {cle:'verbatim',label:'Verbatim'},
      {cle:'action',label:'Action'},
      {cle:'statut_final',label:'Statut'},
      {cle:'traitement',label:'Traitement'},
      {cle:'type_id',label:'Type identite'}
    ],
    token(){ return sessionStorage.getItem('kyc_token')||''; },
    async init(){ await chargerSidebarAdm('referentiels'); await this.charger(); },
    async charger(){
      try{
        const r=await fetch('/api/admin/referentiels',{headers:{'Authorization':'Bearer '+this.token()}});
        if(r.status===401||r.status===403){ window.location.href='/login'; return; }
        if(r.ok){
          const d=await r.json(); const recu=d.referentiels||{}; const clean={};
          for(const c of this.champs){ clean[c.cle]=Array.isArray(recu[c.cle])?recu[c.cle].slice():[]; }
          this.data=clean;
        }
      }catch(e){ this.msg='Erreur de chargement'; this.msgType='err'; }
      this.chargee=true;
    },
    ajouter(cle){
      const v=(this.nouveau[cle]||'').trim(); if(!v) return;
      if(!this.data[cle]) this.data[cle]=[];
      if(this.data[cle].includes(v)){ this.msg='Valeur deja presente'; this.msgType='err'; return; }
      this.data[cle].push(v); this.nouveau[cle]=''; this.msg='';
    },
    supprimer(cle,idx){ this.data[cle].splice(idx,1); },
    monter(cle,idx){ if(idx<=0) return; const a=this.data[cle]; [a[idx-1],a[idx]]=[a[idx],a[idx-1]]; },
    descendre(cle,idx){ const a=this.data[cle]; if(idx>=a.length-1) return; [a[idx+1],a[idx]]=[a[idx],a[idx+1]]; },
    async enregistrer(){
      this.loading=true; this.msg='';
      const propre={};
      for(const c of this.champs){ propre[c.cle]=(this.data[c.cle]||[]).map(x=>String(x||'').trim()).filter(x=>x.length>0); }
      try{
        const r=await fetch('/api/admin/referentiels',{method:'PUT',headers:{'Authorization':'Bearer '+this.token(),'Content-Type':'application/json'},body:JSON.stringify({referentiels:propre})});
        if(r.ok){ this.data=propre; this.msg='Enregistre avec succes'; this.msgType='ok'; }
        else { const e=await r.json().catch(()=>({})); this.msg=e.error||'Erreur enregistrement'; this.msgType='err'; }
      }catch(e){ this.msg='Erreur reseau'; this.msgType='err'; }
      this.loading=false; setTimeout(()=>{ this.msg=''; }, 3000);
    }
  };
}
</script>
</body></html>
