<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - Gross Add GSM</title><script src="https://cdn.tailwindcss.com"></script><script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
<style>
body{font-family:'Inter',system-ui,sans-serif}
.sidebar{background:linear-gradient(180deg,#1A1A1A 0%,#2a2a2a 100%)}
.sb-link{display:flex;align-items:center;padding:.625rem .75rem;border-radius:.5rem;color:#d1d5db;transition:background .15s,color .15s;text-decoration:none}
.sb-link:hover{background:#374151;color:#fff}
.sb-link.active{background:#eab308;color:#111827;font-weight:600}
.gsm-input{width:100%;padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:12px}
.gsm-input:focus{outline:none;border-color:#f2b705;box-shadow:0 0 0 2px rgba(242,183,5,.2)}
.gsm-th{background:#15803d;color:#fff;font-size:11px;font-weight:600;padding:8px 8px;text-align:left;white-space:nowrap}
</style>
<script>
async function chargerSidebar(m){
  const t=sessionStorage.getItem('kyc_token');
  if(!t){window.location.href='/login';return}
  const r=await fetch('/static/pages/_sidebar.html');
  document.getElementById('sidebar-mount').innerHTML=await r.text();
  try{
    const u=JSON.parse(sessionStorage.getItem('kyc_user')||'{}');
    document.getElementById('sb-avatar').textContent=(u.matricule||'??').substring(0,2);
    document.getElementById('sb-nom').textContent=u.prenom||u.matricule||'';
    document.getElementById('sb-matricule').textContent=u.matricule||'';
    document.getElementById('sb-role').textContent=u.role||'';
  }catch(e){}
  if(m){const e=document.querySelector('[data-menu="'+m+'"]');if(e)e.classList.add('active')}
}
async function seDeconnecterGlobal(){
  const t=sessionStorage.getItem('kyc_token');
  if(t){try{await fetch('/api/auth/logout',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}}
  sessionStorage.clear();window.location.href='/login';
}
</script>
</head><body class="bg-gray-100 min-h-screen"><div class="flex min-h-screen"><div id="sidebar-mount"></div>
<main class="flex-1 p-6" x-data="gross()" x-init="init()">

<div class="flex justify-between items-center mb-5 border-b border-gray-200 pb-3">
<h1 class="text-2xl font-bold text-gray-800">🌐 Gross Add GSM — Nouvelle saisie</h1>
<span class="bg-green-600 text-white text-sm font-semibold px-4 py-1.5 rounded-full">✓ Traités aujourd'hui : <span x-text="saisies.length"></span></span>
</div>

<!-- Ligne de saisie -->
<div class="bg-white rounded-xl border border-gray-200 p-4 mb-6">
<div class="overflow-x-auto">
<table class="w-full" style="table-layout:auto;width:100%">
<thead><tr>
<th class="gsm-th rounded-l" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap;border-top-left-radius:8px;border-bottom-left-radius:8px">NUMÉRO *</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">DATE</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">COACH *</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">CONSTAT *</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">PIÈCE *</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">VERBATIM *</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">ACTION *</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">STATUT</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">TRAITEMENT</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">TYPE IDENT. *</th><th class="gsm-th" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap">RAISON</th><th class="gsm-th rounded-r" style="background:#15803d;color:#fff;font-size:10px;font-weight:600;padding:6px 4px;text-align:left;white-space:nowrap;border-top-right-radius:8px;border-bottom-right-radius:8px">CAPTURES</th>
</tr></thead>
<tbody><tr>
<td class="p-1"><input x-model="form.numero" type="text" inputmode="numeric" maxlength="9" placeholder="9 chiffres" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"></td>
<td class="p-1"><input x-model="form.date" type="date" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"></td>
<td class="p-1"><input x-model="form.coach" type="text" placeholder="Coach" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"></td>
<td class="p-1"><select x-model="form.constat" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"><option value="">—</option><template x-for="v in (refs.constat||[])" :key="v"><option x-text="v"></option></template></select></td>
<td class="p-1"><select x-model="form.piece" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"><option value="">—</option><option>ACTE DE NAISSANCE</option><option>CARTE SCOLAIRE</option><option>COPIE D'ACTE DE NAISSANCE</option><option>CARTE D'ETUDIANT</option><option>ATTESTATION D'IMMATRICULATION</option></select></td>
<td class="p-1"><select x-model="form.verbatim" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"><option value="">—</option><option>RAS</option><option>Identité complète</option><option>Nom de l'abonné mal renseigné</option><option>Prénom de l'abonné mal renseigné</option><option>Lieu de naissance mal renseigné</option><option>Type ID mal renseigné</option><option>Nom/Prénom avec accent caractère invalide</option></select></td>
<td class="p-1"><select x-model="form.action" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"><option value="">—</option><option>Accepté</option><option>Edité et Accepté</option><option>Numéro déjà accepté</option><option>A rejeter</option></select></td>
<td class="p-1"><select x-model="form.statut_final" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"><option value="">—</option><option>Accepté</option><option>Inchangé</option></select></td>
<td class="p-1"><select x-model="form.traitement" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"><option value="">—</option><option>Home Box</option><option>Opération Banque Mondiale</option><option>Echoué</option></select></td>
<td class="p-1"><select x-model="form.type_id" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"><option value="">—</option><option>Avec Parrainage</option><option>Sans Parrainage</option></select></td>
<td class="p-1"><input x-model="form.raison" type="text" placeholder="Raison" class="gsm-input" style="width:100%;padding:5px 4px;border:1px solid #cbd5e1;border-radius:6px;font-size:11px;background:#fff;box-sizing:border-box"></td>
<td class="p-1"><label style="cursor:pointer;border:1px solid #cbd5e1;border-radius:6px;padding:5px 6px;font-size:11px;background:#fff;display:block;text-align:center;white-space:nowrap" :style="nbCapForm()>0?'background:#dcfce7;border-color:#16a34a;color:#15803d':''"><span x-text="nbCapForm()>0 ? '✓ '+nbCapForm()+'/3' : '📎 Choisir'"></span><input type="file" accept="image/*" multiple style="display:none" @change="chargerCaptures($event)"></label></td>
</tr></tbody>
</table>
</div>
<div class="flex items-center justify-between mt-3">
<p class="text-xs text-gray-500">Max 5 captures. Champs <span class="text-red-500">*</span> obligatoires. </p>
<div class="flex gap-2">

<button @click="enregistrer()" :disabled="loading||!peutSoumettre()" class="px-5 py-2 bg-blue-700 hover:bg-blue-800 disabled:bg-gray-300 text-white text-sm font-semibold rounded-lg">💾 Enregistrer la saisie</button>
</div>
</div>
<div x-show="erreur" class="mt-2 text-sm text-red-600" x-text="erreur"></div>
</div>

<!-- Mes saisies d'aujourd'hui -->
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
<div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
<h3 class="font-bold text-gray-800">🕐 Mes saisies d'aujourd'hui <span class="text-xs font-normal text-gray-400" x-text="'('+saisies.length+')'"></span></h3>
<input x-model="recherche" type="text" placeholder="🔍 Rechercher dans toutes les colonnes" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm w-72">
</div>
<div class="overflow-x-auto">
<table class="w-full text-xs" style="table-layout:fixed">
<thead class="bg-green-700 text-white"><tr><th class="px-3 py-2 text-left">#</th><th class="px-3 py-2 text-left">NUMÉRO</th><th class="px-3 py-2 text-left">DATE</th><th class="px-3 py-2 text-left">COACH</th><th class="px-3 py-2 text-left">CONSTAT</th><th class="px-3 py-2 text-left">PIÈCE</th><th class="px-3 py-2 text-left">VERBATIM</th><th class="px-3 py-2 text-left">ACTION</th><th class="px-3 py-2 text-left">STATUT</th><th class="px-3 py-2 text-left">TRAITEMENT</th><th class="px-3 py-2 text-left">TYPE IDENT.</th><th class="px-3 py-2 text-left">RAISON</th><th class="px-3 py-2 text-left">CAPTURES</th></tr></thead>
<tbody>
<template x-for="(s,i) in saisiesFiltrees()" :key="s.id">
<tr class="border-t border-gray-100 hover:bg-gray-50">
<td class="px-3 py-2 text-gray-400" x-text="i+1"></td>
<td class="px-3 py-2 font-semibold text-gray-800" x-text="s.numero"></td>
<td class="px-3 py-2 text-gray-600" x-text="formatDate(s.date_saisie)"></td>
<td class="px-3 py-2 text-gray-600" x-text="s.coach||'—'"></td>
<td class="px-3 py-2 text-gray-600" x-text="s.constat||'—'"></td>
<td class="px-3 py-2 text-gray-600" x-text="s.piece||'—'"></td>
<td class="px-3 py-2 text-gray-600" x-text="s.verbatim||'—'"></td>
<td class="px-3 py-2 text-gray-600" x-text="s.action||'—'"></td>
<td class="px-3 py-2 font-semibold" :class="statutClasse(s.statut_final)" x-text="s.statut_final||'—'"></td>
<td class="px-3 py-2 text-gray-600" x-text="s.traitement||'—'"></td>
<td class="px-3 py-2 text-gray-600" x-text="s.type_id||'—'"></td>
<td class="px-3 py-2 text-gray-600" x-text="s.raison||'—'"></td>
<td class="px-3 py-2 text-gray-500" x-text="nbCaptures(s)+'/3'"></td>
</tr>
</template>
<tr x-show="saisiesFiltrees().length===0"><td colspan="13" class="text-center text-gray-400 py-8">Aucune saisie pour aujourd'hui. Saisissez votre première ci-dessus !</td></tr>
</tbody>
</table>
</div>
</div>

<div x-show="toast.message" class="fixed bottom-4 right-4 px-6 py-3 rounded-lg shadow-lg text-white font-semibold z-50" :class="toast.type==='success'?'bg-green-500':'bg-red-500'"><span x-text="toast.message"></span></div>


<div x-show="modalBloc.ouvert" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4" style="display:none"><div class="bg-white rounded-2xl p-6 max-w-md w-full"><div style="display:flex;align-items:center;gap:10px;margin-bottom:12px"><div style="width:42px;height:42px;border-radius:12px;background:#fee2e2;display:flex;align-items:center;justify-content:center;font-size:22px">&#9888;</div><h3 class="text-xl font-bold" style="color:#b91c1c">Saisie a finaliser</h3></div><p class="text-sm text-gray-600">Vous devez d'abord enregistrer la saisie GSM avant de quitter cette page.</p><div class="flex gap-2 mt-6"><button @click="modalBloc.ouvert=false" class="flex-1 py-2 text-white font-semibold rounded-lg" style="background:#dc2626">Compris</button></div></div></div>
</main></div>
<script>
function gross(){
  const formVide=()=>({numero:'',date:new Date().toISOString().slice(0,10),coach:'',constat:'',piece:'',verbatim:'',action:'',statut_final:'',traitement:'',type_id:'',raison:'',captures:[]});
  return {
    user:{},
    form:formVide(),
    refs:{},
    saisies:[],
    recherche:'',
    loading:false,
    erreur:'',
    toast:{message:'',type:'success',timer:null},
    modalBloc:{ouvert:false},
    async init(){
      window.addEventListener('bloc-gsm-finaliser',()=>{ this.modalBloc.ouvert=true; });
      try{
        const tk=sessionStorage.getItem('kyc_token')||'';
        const rr=await fetch('/api/gsm/referentiels',{headers:tk?{'Authorization':'Bearer '+tk}:{}});
        if(rr.ok){ const dd=await rr.json(); this.refs=dd.referentiels||{}; }
      }catch(e){ this.refs=this.refs||{}; }
      try{
        const params=new URLSearchParams(window.location.search);
        const num=params.get('numero');
        const dos=params.get('dossier');
        if(num){ this.form.numero=num; }
        if(dos){ this.form._dossier_id=dos; }
        // Poser le drapeau (numero + dossier) pour pouvoir restaurer apres F5
        if(dos||num){ try{ sessionStorage.setItem('gsm_a_finaliser', JSON.stringify({dossier:dos||'',numero:num||''})); }catch(e){} }
        // CAS F5 : l'URL a perdu numero/dossier mais le drapeau existe -> on restaure
        else {
          try{
            const flag=sessionStorage.getItem('gsm_a_finaliser');
            if(flag){
              let f; try{ f=JSON.parse(flag); }catch(e){ f={dossier:flag,numero:''}; }
              if(f && f.numero){ this.form.numero=f.numero; }
              if(f && f.dossier){ this.form._dossier_id=f.dossier; }
            }
          }catch(e){}
        }
      }catch(e){}
      await chargerSidebar('gross-add');
      try{this.user=JSON.parse(sessionStorage.getItem('kyc_user')||'{}')}catch(e){}
      // Restaurer un éventuel brouillon
      await this.charger();
    },
    async charger(){
      const t=sessionStorage.getItem('kyc_token');
      const d=new Date().toISOString().slice(0,10);
      try{
        const r=await fetch('/api/gsm/mes-saisies?date='+d,{headers:{'Authorization':'Bearer '+t}});
        if(r.status===401){window.location.href='/login';return}
        if(r.ok){const data=await r.json();this.saisies=data.saisies||[]}
      }catch(e){console.error(e)}
    },
    peutSoumettre(){
      const f=this.form;
      return f.numero&&f.coach&&f.constat&&f.piece&&f.verbatim&&f.action&&f.type_id;
    },
    brouillon(){
      try{sessionStorage.setItem('gross_brouillon',JSON.stringify(this.form))}catch(e){}
      this.afficherToast('📝 Brouillon conservé','success');
    },
    async enregistrer(){
      if(!this.peutSoumettre()){this.erreur='Champs obligatoires (*) manquants : Numéro, Coach, Type ID, Constat, Pièce, Verbatim, Action';return}
      this.erreur='';this.loading=true;
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/gsm/libre',{method:'POST',headers:{'Authorization':'Bearer '+t,'Content-Type':'application/json'},body:JSON.stringify(this.form)});
        const data=await r.json();
        if(r.ok){
          this.afficherToast('✅ Saisie enregistrée','success');
          try{sessionStorage.removeItem('gross_brouillon')}catch(e){}
          try{sessionStorage.removeItem('gsm_a_finaliser')}catch(e){}
          this.form=formVide();
          await this.charger();
        }else{this.erreur=data.error||'Erreur';if(data.requis)this.erreur+=' ('+data.requis.join(', ')+')'}
      }catch(e){this.erreur='Erreur réseau'}finally{this.loading=false}
    },
    saisiesFiltrees(){
      if(!this.recherche)return this.saisies;
      const q=this.recherche.toLowerCase();
      return this.saisies.filter(s=>JSON.stringify(s).toLowerCase().includes(q));
    },
    nbCapForm(){return ['capture_a','capture_p','capture_aa'].filter(k=>this.form[k]).length;},
    chargerCaptures(e){
      const fichiers=Array.from(e.target.files).slice(0,5);
      this.form.captures=[];
      fichiers.forEach((f)=>{
        const img=new Image(); const rd=new FileReader();
        rd.onload=()=>{ img.onload=()=>{
          const max=900; let w=img.width,h=img.height;
          if(w>max||h>max){ if(w>h){h=Math.round(h*max/w);w=max;}else{w=Math.round(w*max/h);h=max;} }
          const c=document.createElement('canvas'); c.width=w; c.height=h;
          c.getContext('2d').drawImage(img,0,0,w,h);
          this.form.captures.push(c.toDataURL('image/jpeg',0.7));
        }; img.src=rd.result; };
        rd.readAsDataURL(f);
      });
    },
    nbCaptures(s){return ['capture_a','capture_p','capture_aa'].filter(k=>s[k]).length},
    formatDate(s){if(!s)return'';const p=s.split('-');return p.length===3?(p[2]+'/'+p[1]+'/'+p[0]):s},
    statutClasse(s){const v=(''+(s||'')).toLowerCase();if(v.includes('accept'))return'text-green-600';if(v.includes('rejet'))return'text-red-600';return'text-gray-600'},
    afficherToast(m,t){this.toast.message=m;this.toast.type=t||'success';if(this.toast.timer)clearTimeout(this.toast.timer);this.toast.timer=setTimeout(()=>{this.toast.message=''},3000)}
  };
}
</script>
</body></html>
