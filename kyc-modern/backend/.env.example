# ────────────────────────────────────────────
# KYC Congo V4 – Configuration (.env)
# ────────────────────────────────────────────

# Serveur
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Base de données MySQL (obligatoire)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=kyc_v4
DB_POOL_LIMIT=10

# JWT
JWT_SECRET=CHANGEZ_MOI_SECRET_MINIMUM_32_CARACTERES_AAAA
JWT_EXPIRES_IN=8h

# Sécurité
BCRYPT_COST=12
PASSWORD_MIN_LENGTH=8
ACCOUNT_LOCK_AFTER_FAILS=5
ACCOUNT_LOCK_DURATION=900

# Rate-limit connexion
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=60000

# Uploads
UPLOAD_CNI=./uploads/cni
UPLOAD_GSM=./uploads/gsm

# Distribution auto (milliseconds)
DISTRIBUTION_INTERVAL_MS=2000
DISTRIBUTION_ABANDON_SEC=120

# AWS Rekognition (optionnel – reconnaissance faciale)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
REKOG_SIMILARITY_THRESHOLD=50
FACE_MATCH_THRESHOLD=70

# TURN / coturn (requis pour la signalisation WebRTC hors réseau local)
TURN_SHARED_SECRET=
TURN_HOST=turn.kyc-congo.com
