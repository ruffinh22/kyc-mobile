<script src="/static/pages/reporting-logic.js"></script>
<script>
(function(){
  function demarrer(){
    if(typeof chargerSidebarSup==='function'){ try{ chargerSidebarSup('reporting'); }catch(e){} }
    if(typeof initReporting==='function'){ try{ initReporting(); }catch(e){} }
  }
  if(document.readyState==='loading'){ window.addEventListener('DOMContentLoaded',demarrer); }
  else { setTimeout(demarrer,50); }
})();
</script>
