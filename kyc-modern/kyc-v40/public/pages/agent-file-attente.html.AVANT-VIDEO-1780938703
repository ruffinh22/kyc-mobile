<span :style="dureeMinutes(d.created_at)>5?'background:#fceaea;color:#b91c1c;font-weight:600':'background:#f1f5f9;color:#475569'" style="font-size:11px;padding:2px 8px;border-radius:6px" x-text="dureeMinutes(d.created_at)+' min'"></span>
