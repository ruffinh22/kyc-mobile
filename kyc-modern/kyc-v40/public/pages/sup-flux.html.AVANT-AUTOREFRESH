<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - Flux & Prédiction</title><script src="https://cdn.tailwindcss.com"></script><script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
body{font-family:Inter,system-ui,sans-serif;--muted:#6b7280;--bd:#e5e7eb;--bg:#f3f4f6}
.sidebar{background:linear-gradient(180deg,#0c1e3e 0%,#1e3a5f 100%)}
.sb-link{display:flex;align-items:center;padding:.625rem .75rem;border-radius:.5rem;color:#cbd5e1;transition:background .15s,color .15s;text-decoration:none}
.sb-link:hover{background:#1e293b;color:#fff}
.sb-link.active{background:#3b82f6;color:#fff;font-weight:600}
.fcard{background:#fff;border:1px solid var(--bd);border-radius:12px;padding:14px 16px}
.fkpi{background:#fff;border:1px solid var(--bd);border-top:4px solid #FFC300;border-radius:14px;padding:22px 16px;text-align:center;display:flex;flex-direction:column;justify-content:center;min-height:96px}
.ftab{padding:7px 14px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;border:1px solid var(--bd);background:#fff;color:#6b7280}
.ftab.on{background:#1A1A1A;color:#fff;border-color:#1A1A1A}
.feff th{padding:8px 12px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);border-bottom:1px solid var(--bd)}
</style>
<script>
async function chargerSidebarSup(m){
  const t=sessionStorage.getItem('kyc_token');
  if(!t){window.location.href='/login';return}
  const u=JSON.parse(sessionStorage.getItem('kyc_user')||'{}');
  if(u.role!=='superviseur'&&u.role!=='admin'){window.location.href='/agent/dashboard';return}
  const r=await fetch('/static/pages/_sidebar-sup.html');
  document.getElementById('sidebar-mount').innerHTML=await r.text();
  try{
    document.getElementById('sb-avatar').textContent=(u.matricule||'??').substring(0,2);
    document.getElementById('sb-nom').textContent=u.prenom||u.matricule||'';
    document.getElementById('sb-matricule').textContent=u.matricule||'';
    document.getElementById('sb-role').textContent=u.role||'';
  }catch(e){}
  if(m){const e=document.querySelector('[data-menu="'+m+'"]');if(e)e.classList.add('active')}
}
async function seDeconnecterGlobal(){
  const t=sessionStorage.getItem('kyc_token');
  if(t){try{await fetch('/api/auth/logout',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}}
  sessionStorage.clear();window.location.href='/login';
}
</script>
</head><body class="bg-gray-100 min-h-screen"><div class="flex min-h-screen"><div id="sidebar-mount"></div>
<main class="flex-1 min-w-0 p-4" style="background:var(--bg)">

<div class="flex items-center justify-between mb-3">
<div style="font-size:18px;font-weight:900;color:#1A1A1A">📡 Gestion du Flux &amp; Analyse Prédictive <span style="font-size:10px;background:#1A1A1A;color:#FFC300;border-radius:6px;padding:2px 7px;vertical-align:middle">IA</span></div>
<div class="flex items-center gap-3"><span style="font-size:11px;color:var(--muted)" id="flux-last-update"></span><button onclick="chargerFlux()" class="px-3 py-1.5 rounded-lg text-sm font-semibold border border-yellow-400 text-yellow-600 hover:bg-yellow-50">🔄 Actualiser</button></div>
</div>

<div id="flux-alerte" style="display:none;align-items:center;gap:14px;background:#fffbeb;border:1.5px solid #fde68a;border-radius:14px;padding:16px 20px;margin-bottom:16px"><span style="font-size:26px;flex-shrink:0" id="flux-alerte-ico">⚠️</span><div style="flex:1"><div style="font-size:13px;font-weight:800" id="flux-alerte-titre"></div><div style="font-size:12px;margin-top:3px;line-height:1.5" id="flux-alerte-msg"></div></div><div style="text-align:center"><div style="font-size:22px;font-weight:900" id="flux-agents-rec">–</div><div style="font-size:9px;color:var(--muted)">agents conseillés</div></div></div>

<!-- 5 KPI -->
<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:16px">
<div style="background:#fff;border:1px solid #e8e8ec;border-top:4px solid #eab308;border-radius:14px;padding:20px 14px;text-align:center;display:flex;flex-direction:column;justify-content:center;min-height:104px;box-shadow:0 1px 3px rgba(0,0,0,.04)">
<div style="font-size:42px;font-weight:800;color:#eab308;line-height:1" id="fkpi-entrant">0</div>
<div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-top:10px;font-weight:600">Flux entrant / h</div>
</div><div style="background:#fff;border:1px solid #e8e8ec;border-top:4px solid #eab308;border-radius:14px;padding:20px 14px;text-align:center;display:flex;flex-direction:column;justify-content:center;min-height:104px;box-shadow:0 1px 3px rgba(0,0,0,.04)">
<div style="font-size:42px;font-weight:800;color:#eab308;line-height:1" id="fkpi-cours">0</div>
<div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-top:10px;font-weight:600">En traitement</div>
</div><div style="background:#fff;border:1px solid #e8e8ec;border-top:4px solid #dc2626;border-radius:14px;padding:20px 14px;text-align:center;display:flex;flex-direction:column;justify-content:center;min-height:104px;box-shadow:0 1px 3px rgba(0,0,0,.04)">
<div style="font-size:42px;font-weight:800;color:#dc2626;line-height:1" id="fkpi-attente">0</div>
<div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-top:10px;font-weight:600">File d'attente</div>
</div><div style="background:#fff;border:1px solid #e8e8ec;border-top:4px solid #16a34a;border-radius:14px;padding:20px 14px;text-align:center;display:flex;flex-direction:column;justify-content:center;min-height:104px;box-shadow:0 1px 3px rgba(0,0,0,.04)">
<div style="font-size:42px;font-weight:800;color:#16a34a;line-height:1" id="fkpi-capacite">0</div>
<div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-top:10px;font-weight:600">Capacité / h</div>
</div><div id="fkpi-sat-card" style="background:#fff;border:1px solid #e8e8ec;border-top:4px solid #16a34a;border-radius:14px;padding:20px 14px;text-align:center;display:flex;flex-direction:column;justify-content:center;min-height:104px;box-shadow:0 1px 3px rgba(0,0,0,.04)">
<div style="font-size:42px;font-weight:800;line-height:1;color:#16a34a" id="fkpi-saturation">–</div>
<div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;margin-top:10px;font-weight:600">Saturation</div>
</div>
</div>

<!-- Prévision 4h + Analyse IA -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
<div class="fcard">
<div class="flex items-center justify-between mb-2"><h3 style="margin:0;font-size:13px;font-weight:800">🔮 Prévision — Prochaines 4 heures</h3><span style="font-size:10px;color:var(--muted)" id="flux-base-hist">–</span></div>
<div id="flux-prev4h" style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px"></div>
</div>
<div class="fcard" style="background:linear-gradient(135deg,#fffbeb,#fff)">
<div class="flex items-center gap-2 mb-2"><h3 style="margin:0;font-size:13px;font-weight:800">🤖 Analyse IA</h3><span style="font-size:9px;font-weight:700;padding:2px 8px;border-radius:8px" id="flux-confiance-badge">–</span></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px">
<div style="background:#fff;border:1px solid var(--bd);border-radius:8px;padding:10px"><div style="font-size:9px;font-weight:700;color:#FFC300;text-transform:uppercase;margin-bottom:5px">📊 Pic prévu</div><div style="font-size:17px;font-weight:800;color:#1A1A1A" id="flux-pic-heure">–</div><div style="font-size:10px;color:var(--muted);margin-top:2px" id="flux-pic-vol">–</div></div>
<div style="background:#fff;border:1px solid var(--bd);border-radius:8px;padding:10px"><div style="font-size:9px;font-weight:700;color:#16a34a;text-transform:uppercase;margin-bottom:5px">🎯 Fin de journée</div><div style="font-size:17px;font-weight:800;color:#1A1A1A" id="flux-fin-jour">–</div><div style="font-size:10px;color:var(--muted);margin-top:2px" id="flux-fin-sub">–</div></div>
</div>
<div id="flux-insights" style="display:flex;flex-direction:column;gap:5px"></div>
</div>
</div>

<!-- Historique courbe -->
<div class="fcard mb-3">
<div class="flex items-center justify-between mb-2"><h3 style="margin:0;font-size:13px;font-weight:800">📈 Historique &amp; Tendance — Derniers jours</h3>
<div class="flex gap-1"><button id="fbtn-7" onclick="setFluxPeriode(7)" class="ftab on">7j</button><button id="fbtn-14" onclick="setFluxPeriode(14)" class="ftab">14j</button><button id="fbtn-30" onclick="setFluxPeriode(30)" class="ftab">30j</button></div>
</div>
<canvas id="chart-flux-histo" style="max-height:220px"></canvas>
</div>

<!-- Heatmap -->
<div class="fcard mb-3">
<h3 style="margin:0 0 10px;font-size:13px;font-weight:800">🗓 Heatmap horaire — Volume moyen par jour &amp; tranche</h3>
<div id="flux-heatmap" style="overflow-x:auto"></div>
</div>

<!-- Recommandations effectif -->
<div class="fcard">
<div class="flex items-center justify-between mb-2"><h3 style="margin:0;font-size:13px;font-weight:800">👥 Recommandations effectif</h3><span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:8px;background:#f0fdf4;color:#16a34a" id="flux-agents-actifs">–</span></div>
<div class="flex gap-1 mb-3"><button id="feff-tab-jour" onclick="setEffVue('journee')" class="ftab on">⏰ Journée</button><button id="feff-tab-day" onclick="setEffVue('jour')" class="ftab">📆 Par jour</button><button id="feff-tab-sem" onclick="setEffVue('semaine')" class="ftab">🗓 Par semaine</button></div>
<div id="feff-journee">
<table class="w-full feff" style="font-size:12px"><thead><tr><th style="text-align:left">Tranche horaire</th><th>Flux prévu</th><th>Agents min.</th><th>Agents optimal</th><th>Intensité</th><th>Couverture</th><th style="text-align:left">Action recommandée</th></tr></thead><tbody id="flux-tbody-effectif"></tbody></table>
</div>
<div id="feff-jour" style="display:none">
<table class="w-full feff" style="font-size:12px"><thead><tr><th style="text-align:left">Jour</th><th>Volume moyen</th><th>Pic horaire</th><th>Agents min.</th><th>Agents optimal</th><th>Intensité</th><th style="text-align:left">Profil</th></tr></thead><tbody id="flux-tbody-day"></tbody></table>
</div>
<div id="feff-semaine" style="display:none">
<p style="font-size:11px;color:var(--muted);margin-bottom:10px">Analyse des 5 dernières semaines avec recommandations d'effectif hebdomadaire.</p>
<table class="w-full feff" style="font-size:12px"><thead><tr><th style="text-align:left">Semaine</th><th>Total</th><th>Moy/jour</th><th>Pic jour</th><th>Agents min.</th><th>Agents optimal</th><th>Tendance</th><th style="text-align:left">Recommandation</th></tr></thead><tbody id="flux-tbody-semaine"></tbody></table>
<div id="flux-semaine-resume" style="margin-top:12px;padding:12px 16px;border-radius:8px;background:linear-gradient(135deg,#f0fdf4,#fff);border:1.5px solid #16a34a;display:none"><div style="font-size:12px" id="flux-semaine-resume-txt"></div></div>
</div>
</div>

</main></div>
<script src="/static/pages/flux-logic.js"></script>
<script>
(function(){
  function demarrer(){
    if(typeof chargerSidebarSup==='function'){ try{ chargerSidebarSup('flux'); }catch(e){} }
    if(typeof initFlux==='function'){ initFlux(); }
  }
  if(document.readyState==='loading'){ window.addEventListener('DOMContentLoaded',demarrer); }
  else { setTimeout(demarrer,50); }
})();
</script>
</body></html>