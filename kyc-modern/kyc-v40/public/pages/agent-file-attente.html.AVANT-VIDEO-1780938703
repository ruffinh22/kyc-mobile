<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - File d'attente</title><script src="https://cdn.tailwindcss.com"></script><script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
<style>
body{font-family:'Inter',system-ui,sans-serif}
.sidebar{background:linear-gradient(180deg,#1A1A1A 0%,#2a2a2a 100%)}
.sb-link{display:flex;align-items:center;padding:.625rem .75rem;border-radius:.5rem;color:#d1d5db;transition:background .15s,color .15s;text-decoration:none}
.sb-link:hover{background:#374151;color:#fff}
.sb-link.active{background:#eab308;color:#111827;font-weight:600}
</style>
<script>
async function chargerSidebar(m){
  const t=sessionStorage.getItem('kyc_token');
  if(!t){window.location.href='/login';return}
  const r=await fetch('/static/pages/_sidebar.html');
  document.getElementById('sidebar-mount').innerHTML=await r.text();
  try{
    const u=JSON.parse(sessionStorage.getItem('kyc_user')||'{}');
    document.getElementById('sb-avatar').textContent=(u.matricule||'??').substring(0,2);
    document.getElementById('sb-nom').textContent=u.prenom||u.matricule||'';
    document.getElementById('sb-matricule').textContent=u.matricule||'';
    document.getElementById('sb-role').textContent=u.role||'';
  }catch(e){}
  if(m){const e=document.querySelector('[data-menu="'+m+'"]');if(e)e.classList.add('active')}
}
async function seDeconnecterGlobal(){
  const t=sessionStorage.getItem('kyc_token');
  if(t){try{await fetch('/api/auth/logout',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}}
  sessionStorage.clear();window.location.href='/login';
}
</script>
</head><body class="bg-gray-50 min-h-screen"><div class="flex min-h-screen"><div id="sidebar-mount"></div>
<main class="flex-1 p-6" x-data="fileAttente()" x-init="init()">
<div class="flex justify-between mb-6"><div><h1 class="text-2xl font-bold text-gray-800">📋 File d'attente</h1><p class="text-gray-500 text-sm">Mis à jour: <span x-text="derniereMaj"></span></p></div><div class="flex gap-2">
<button @click="demanderAide()" :disabled="actionEnCours" style="font-size:13px;background:#fff;color:#dc2626;border:1px solid #fecaca;padding:6px 14px;border-radius:999px;cursor:pointer;font-weight:600">🆘 Aide</button>
<button @click="togglePause()" style="font-size:13px;background:#fff;color:#d97706;border:1px solid #fed7aa;padding:6px 14px;border-radius:999px;cursor:pointer;font-weight:600">⏸️ Pause</button>
<button @click="charger()" style="font-size:13px;background:#fff;color:#475569;border:1px solid #e2e8f0;padding:6px 14px;border-radius:999px;cursor:pointer;font-weight:600">🔄 Rafraîchir</button>
</div></div>
<div x-show="dossiersAttenteVieux>0" class="bg-red-500 text-white text-center py-2 mb-4 rounded">⚠️ <span x-text="dossiersAttenteVieux"></span> dossier(s) en attente > 5 min !</div>
<div class="grid grid-cols-7 gap-2 mb-4">
<div style="background:#fff;border-radius:12px;padding:12px 8px;text-align:center;border-top:3px solid #f97316"><div style="font-size:22px;font-weight:600;color:#0f172a" x-text="stats.en_attente">0</div><div style="font-size:11px;color:#64748b;margin-top:2px">En attente</div></div>
<div style="background:#fff;border-radius:12px;padding:12px 8px;text-align:center;border-top:3px solid #94a3b8"><div style="font-size:22px;font-weight:600;color:#0f172a" x-text="stats.total">0</div><div style="font-size:11px;color:#64748b;margin-top:2px">Total</div></div>
<div style="background:#fff;border-radius:12px;padding:12px 8px;text-align:center;border-top:3px solid #3b82f6"><div style="font-size:22px;font-weight:600;color:#0f172a" x-text="stats.en_cours">0</div><div style="font-size:11px;color:#64748b;margin-top:2px">En cours</div></div>
<div style="background:#fff;border-radius:12px;padding:12px 8px;text-align:center;border-top:3px solid #22c55e"><div style="font-size:22px;font-weight:600;color:#0f172a" x-text="stats.accepte">0</div><div style="font-size:11px;color:#64748b;margin-top:2px">Acceptés</div></div>
<div style="background:#fff;border-radius:12px;padding:12px 8px;text-align:center;border-top:3px solid #ef4444"><div style="font-size:22px;font-weight:600;color:#0f172a" x-text="stats.rejete">0</div><div style="font-size:11px;color:#64748b;margin-top:2px">Rejetés</div></div>
<div style="background:#fff;border-radius:12px;padding:12px 8px;text-align:center;border-top:3px solid #8b5cf6"><div style="font-size:22px;font-weight:600;color:#0f172a" x-text="tempsMoyenTraitement()+' min'">0</div><div style="font-size:11px;color:#64748b;margin-top:2px">Tps moyen</div></div>
