<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - Mes GSM et captures</title><script src="https://cdn.tailwindcss.com"></script><script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
<style>
body{font-family:'Inter',system-ui,sans-serif}
.sidebar{background:linear-gradient(180deg,#1A1A1A 0%,#2a2a2a 100%)}
.sb-link{display:flex;align-items:center;padding:.625rem .75rem;border-radius:.5rem;color:#d1d5db;transition:background .15s,color .15s;text-decoration:none}
.sb-link:hover{background:#374151;color:#fff}
.sb-link.active{background:#eab308;color:#111827;font-weight:600}
.fheader{position:relative}
.fbtn{margin-left:4px;cursor:pointer;color:#bbf7d0;font-size:10px;user-select:none}
.fbtn.actif{color:#fde047}
.fpop{position:absolute !important;top:100% !important;left:0 !important;z-index:50 !important;background:#fff !important;border:1px solid #d1d5db !important;border-radius:8px !important;box-shadow:0 6px 20px rgba(0,0,0,.15) !important;padding:8px !important;width:220px !important;max-height:280px !important;overflow-y:auto !important;overflow-x:hidden !important;margin-top:4px !important;text-transform:none !important;text-align:left !important}
.fpop label{display:flex !important;flex-direction:row !important;align-items:center !important;gap:6px !important;padding:4px !important;margin:0 !important;font-size:12px !important;color:#374151 !important;cursor:pointer !important;border-radius:4px !important;font-weight:400 !important;white-space:nowrap !important;line-height:1.3 !important}
.fpop label:hover{background:#f3f4f6 !important}
.fpop label input[type=checkbox]{margin:0 !important;flex:none !important;width:14px !important;height:14px !important}
.fpop label span{overflow:hidden !important;text-overflow:ellipsis !important;white-space:nowrap !important;flex:1 !important}
.fpop .facts{display:flex !important;gap:6px !important;margin-bottom:6px !important;border-bottom:1px solid #eee !important;padding-bottom:6px !important}
.fpop .facts button{flex:1 !important;font-size:11px !important;padding:3px !important;border:1px solid #d1d5db !important;border-radius:5px !important;background:#f8fafc !important;cursor:pointer !important;color:#374151 !important}
</style>
<script>
async function chargerSidebar(m){
  const t=sessionStorage.getItem('kyc_token');
  if(!t){window.location.href='/login';return}
  const r=await fetch('/static/pages/_sidebar.html');
  document.getElementById('sidebar-mount').innerHTML=await r.text();
  try{
    const u=JSON.parse(sessionStorage.getItem('kyc_user')||'{}');
    document.getElementById('sb-avatar').textContent=(u.matricule||'??').substring(0,2);
    document.getElementById('sb-nom').textContent=u.prenom||u.matricule||'';
    document.getElementById('sb-matricule').textContent=u.matricule||'';
    document.getElementById('sb-role').textContent=u.role||'';
  }catch(e){}
  if(m){const e=document.querySelector('[data-menu="'+m+'"]');if(e)e.classList.add('active')}
}
async function seDeconnecterGlobal(){
  const t=sessionStorage.getItem('kyc_token');
  if(t){try{await fetch('/api/auth/logout',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}}
  sessionStorage.clear();window.location.href='/login';
}
</script>
</head><body class="bg-gray-100 min-h-screen"><div class="flex min-h-screen"><div id="sidebar-mount"></div>
<main class="flex-1 min-w-0 p-6" x-data="hist()" x-init="init()" @click="pop=''">

<div class="mb-5 border-b border-gray-200 pb-3"><h1 class="text-2xl font-bold text-gray-800">📷 Mes GSM et captures</h1></div>

<div class="bg-white rounded-xl border border-gray-200 p-4 mb-5 flex flex-wrap items-end gap-3">
<div><label class="block text-xs font-semibold text-gray-500 mb-1">Du</label><input type="date" x-model="debut" class="px-3 py-2 border border-gray-300 rounded-lg text-sm"></div>
<div><label class="block text-xs font-semibold text-gray-500 mb-1">Au</label><input type="date" x-model="fin" class="px-3 py-2 border border-gray-300 rounded-lg text-sm"></div>
<button @click="charger()" class="px-4 py-2 bg-blue-700 hover:bg-blue-800 text-white text-sm font-semibold rounded-lg">🔍 Afficher</button>
<button @click="moisCourant()" class="px-4 py-2 bg-yellow-500 hover:bg-yellow-600 text-white text-sm font-semibold rounded-lg">↺ Mois en cours</button>
<div class="flex-1"></div>
<input x-model="recherche" type="text" placeholder="🔍 Rechercher" class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-64">
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
<div class="px-4 py-3 border-b border-gray-100"><h3 class="font-bold text-gray-800">🗂 Historique <span class="text-xs font-normal text-gray-400" x-text="'('+lignesFiltrees().length+')'"></span></h3></div>
<div style="overflow-x:hidden">
<table class="w-full" style="table-layout:fixed;font-size:10px">
<thead class="bg-green-700 text-white"><tr><th class="px-1 py-2 text-left" style="width:3%">#</th><th class="px-1 py-2 text-left fheader" style="width:8%">NUMÉRO <span class="fbtn" :class="{actif:fcol['numero']}" @click.stop="togglePop('numero')">&#9660;</span><div class="fpop" x-show="pop==='numero'" @click.stop style="display:none"><div class="facts"><button @click="selAll('numero')">Tout</button><button @click="selNone('numero')">Aucun</button></div><template x-for="v in valeursDe('numero')" :key="v"><label><input type="checkbox" :checked="estCoche('numero',v)" @change="toggleVal('numero',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:7%">DATE <span class="fbtn" :class="{actif:fcol['date_saisie']}" @click.stop="togglePop('date_saisie')">&#9660;</span><div class="fpop" x-show="pop==='date_saisie'" @click.stop style="display:none"><div class="facts"><button @click="selAll('date_saisie')">Tout</button><button @click="selNone('date_saisie')">Aucun</button></div><template x-for="v in valeursDe('date_saisie')" :key="v"><label><input type="checkbox" :checked="estCoche('date_saisie',v)" @change="toggleVal('date_saisie',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:7%">COACH <span class="fbtn" :class="{actif:fcol['coach']}" @click.stop="togglePop('coach')">&#9660;</span><div class="fpop" x-show="pop==='coach'" @click.stop style="display:none"><div class="facts"><button @click="selAll('coach')">Tout</button><button @click="selNone('coach')">Aucun</button></div><template x-for="v in valeursDe('coach')" :key="v"><label><input type="checkbox" :checked="estCoche('coach',v)" @change="toggleVal('coach',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:9%">CONSTAT <span class="fbtn" :class="{actif:fcol['constat']}" @click.stop="togglePop('constat')">&#9660;</span><div class="fpop" x-show="pop==='constat'" @click.stop style="display:none"><div class="facts"><button @click="selAll('constat')">Tout</button><button @click="selNone('constat')">Aucun</button></div><template x-for="v in valeursDe('constat')" :key="v"><label><input type="checkbox" :checked="estCoche('constat',v)" @change="toggleVal('constat',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:8%">PIÈCE <span class="fbtn" :class="{actif:fcol['piece']}" @click.stop="togglePop('piece')">&#9660;</span><div class="fpop" x-show="pop==='piece'" @click.stop style="display:none"><div class="facts"><button @click="selAll('piece')">Tout</button><button @click="selNone('piece')">Aucun</button></div><template x-for="v in valeursDe('piece')" :key="v"><label><input type="checkbox" :checked="estCoche('piece',v)" @change="toggleVal('piece',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:9%">VERBATIM <span class="fbtn" :class="{actif:fcol['verbatim']}" @click.stop="togglePop('verbatim')">&#9660;</span><div class="fpop" x-show="pop==='verbatim'" @click.stop style="display:none"><div class="facts"><button @click="selAll('verbatim')">Tout</button><button @click="selNone('verbatim')">Aucun</button></div><template x-for="v in valeursDe('verbatim')" :key="v"><label><input type="checkbox" :checked="estCoche('verbatim',v)" @change="toggleVal('verbatim',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:8%">ACTION <span class="fbtn" :class="{actif:fcol['action']}" @click.stop="togglePop('action')">&#9660;</span><div class="fpop" x-show="pop==='action'" @click.stop style="display:none"><div class="facts"><button @click="selAll('action')">Tout</button><button @click="selNone('action')">Aucun</button></div><template x-for="v in valeursDe('action')" :key="v"><label><input type="checkbox" :checked="estCoche('action',v)" @change="toggleVal('action',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:6%">STATUT <span class="fbtn" :class="{actif:fcol['statut_final']}" @click.stop="togglePop('statut_final')">&#9660;</span><div class="fpop" x-show="pop==='statut_final'" @click.stop style="display:none"><div class="facts"><button @click="selAll('statut_final')">Tout</button><button @click="selNone('statut_final')">Aucun</button></div><template x-for="v in valeursDe('statut_final')" :key="v"><label><input type="checkbox" :checked="estCoche('statut_final',v)" @change="toggleVal('statut_final',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:8%">TRAITEMENT <span class="fbtn" :class="{actif:fcol['traitement']}" @click.stop="togglePop('traitement')">&#9660;</span><div class="fpop" x-show="pop==='traitement'" @click.stop style="display:none"><div class="facts"><button @click="selAll('traitement')">Tout</button><button @click="selNone('traitement')">Aucun</button></div><template x-for="v in valeursDe('traitement')" :key="v"><label><input type="checkbox" :checked="estCoche('traitement',v)" @change="toggleVal('traitement',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:7%">TYPE ID. <span class="fbtn" :class="{actif:fcol['type_id']}" @click.stop="togglePop('type_id')">&#9660;</span><div class="fpop" x-show="pop==='type_id'" @click.stop style="display:none"><div class="facts"><button @click="selAll('type_id')">Tout</button><button @click="selNone('type_id')">Aucun</button></div><template x-for="v in valeursDe('type_id')" :key="v"><label><input type="checkbox" :checked="estCoche('type_id',v)" @change="toggleVal('type_id',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left fheader" style="width:7%">RAISON <span class="fbtn" :class="{actif:fcol['raison']}" @click.stop="togglePop('raison')">&#9660;</span><div class="fpop" x-show="pop==='raison'" @click.stop style="display:none"><div class="facts"><button @click="selAll('raison')">Tout</button><button @click="selNone('raison')">Aucun</button></div><template x-for="v in valeursDe('raison')" :key="v"><label><input type="checkbox" :checked="estCoche('raison',v)" @change="toggleVal('raison',v)"><span x-text="v"></span></label></template></div></th><th class="px-1 py-2 text-left" style="width:13%">CAPTURES</th></tr></thead>
<tbody>
<template x-for="(s,i) in lignesFiltrees()" :key="s.id">
<tr class="border-t border-gray-100 hover:bg-gray-50" style="word-break:break-word;vertical-align:top">
<td class="px-1 py-2 text-gray-400" x-text="i+1"></td>
<td class="px-1 py-2 font-semibold text-gray-800" x-text="s.numero"></td>
<td class="px-1 py-2 text-gray-600" x-text="formatDate(s.date_saisie)"></td>
<td class="px-1 py-2 text-gray-600" x-text="s.coach||'—'"></td>
<td class="px-1 py-2 text-gray-600" x-text="s.constat||'—'"></td>
<td class="px-1 py-2 text-gray-600" x-text="s.piece||'—'"></td>
<td class="px-1 py-2 text-gray-600" x-text="s.verbatim||'—'"></td>
<td class="px-1 py-2 text-gray-600" x-text="s.action||'—'"></td>
<td class="px-1 py-2 font-semibold" :class="statutClasse(s.statut_final)" x-text="s.statut_final||'—'"></td>
<td class="px-1 py-2 text-gray-600" x-text="s.traitement||'—'"></td>
<td class="px-1 py-2 text-gray-600" x-text="s.type_id||'—'"></td>
<td class="px-1 py-2 text-gray-600" x-text="s.raison||'—'"></td>
<td class="px-1 py-2">
<div class="flex gap-1 flex-wrap" style="max-width:160px">
<template x-for="(img,ix) in capsListe(s)" :key="ix">
<div class="w-8 h-8 bg-gray-100 rounded border border-gray-200 overflow-hidden flex items-center justify-center flex-shrink-0">
<img :src="img" @click="agrandir(img)" class="w-full h-full object-cover cursor-pointer">
</div>
</template>
<span x-show="capsListe(s).length===0" class="text-gray-300 text-[10px]">—</span>
</div>
</td>
</tr>
</template>
<tr x-show="lignesFiltrees().length===0"><td colspan="13" class="text-center text-gray-400 py-8">Aucune saisie sur cette période</td></tr>
</tbody>
</table>
</div>
</div>

<div x-show="lightbox" @click="lightbox=''" class="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50 p-4 cursor-zoom-out"><img :src="lightbox" class="max-h-full max-w-full rounded-lg shadow-2xl"></div>

<div x-show="toast.message" class="fixed bottom-4 right-4 px-6 py-3 rounded-lg shadow-lg text-white font-semibold z-50 bg-red-500"><span x-text="toast.message"></span></div>

</main></div>
<script>
function hist(){
  return {
    user:{},
    debut:'',
    fin:'',
    saisies:[],
    vignettes:{},
    recherche:'',
    fcol:{},
    pop:'',
    lightbox:'',
    toast:{message:'',timer:null},
    async init(){
      await chargerSidebar('mes-gsm');
      try{this.user=JSON.parse(sessionStorage.getItem('kyc_user')||'{}')}catch(e){}
      this.moisCourant(false);
      await this.charger();
    },
    moisCourant(recharger){
      const now=new Date();
      const pad=n=>String(n).padStart(2,'0');
      this.debut=now.getFullYear()+'-'+pad(now.getMonth()+1)+'-01';
      this.fin=now.getFullYear()+'-'+pad(now.getMonth()+1)+'-'+pad(now.getDate());
      if(recharger!==false)this.charger();
    },
    async charger(){
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/gsm/mes-historique?debut='+this.debut+'&fin='+this.fin,{headers:{'Authorization':'Bearer '+t}});
        if(r.status===401){window.location.href='/login';return}
        if(r.ok){const d=await r.json();this.saisies=d.saisies||[];await this.chargerVignettes()}
      }catch(e){console.error(e)}
    },
    capsListe(s){
      // Nouvelles captures (base64 dans colonne captures)
      if(s.captures){
        try{ const arr=typeof s.captures==='string'?JSON.parse(s.captures):s.captures; if(Array.isArray(arr)&&arr.length) return arr; }catch(e){}
      }
      // Anciennes captures (fichiers via vignettes)
      const out=[];
      for(const cap of ['capture_a','capture_p','capture_aa']){
        if(s[cap]&&this.vignettes[s[cap]]) out.push(this.vignettes[s[cap]]);
      }
      return out;
    },
    async chargerVignettes(){
      const t=sessionStorage.getItem('kyc_token');
      for(const s of this.saisies){
        for(const cap of ['capture_a','capture_p','capture_aa']){
          const rel=s[cap];
          if(!rel||this.vignettes[rel])continue;
          try{
            const r=await fetch('/api/gsm/captures/'+rel,{headers:{'Authorization':'Bearer '+t}});
            if(r.ok){const b=await r.blob();this.vignettes[rel]=URL.createObjectURL(b)}
          }catch(e){}
        }
      }
    },
    valLisible(c,s){
      if(c==='date_saisie') return this.formatDate(s.date_saisie)||'(vide)';
      const v=s[c]; return (v===null||v===undefined||v==='')?'(vide)':String(v);
    },
    valeursDe(c){
      const set=new Set();
      for(const s of this.saisies){ set.add(this.valLisible(c,s)); }
      return [...set].sort();
    },
    togglePop(c){ this.pop=(this.pop===c)?'':c; },
    estCoche(c,v){ if(!this.fcol[c])return true; return this.fcol[c].includes(v); },
    toggleVal(c,v){
      const f=Object.assign({}, this.fcol);
      let liste = f[c] ? f[c].slice() : this.valeursDe(c).slice();
      const i=liste.indexOf(v);
      if(i>=0) liste.splice(i,1); else liste.push(v);
      if(liste.length===this.valeursDe(c).length){ delete f[c]; }
      else { f[c]=liste; }
      this.fcol=f;
    },
    selAll(c){ const f=Object.assign({}, this.fcol); delete f[c]; this.fcol=f; },
    selNone(c){ const f=Object.assign({}, this.fcol); f[c]=[]; this.fcol=f; },
    lignesFiltrees(){
      let arr=this.saisies;
      // Filtres entonnoir par colonne
      for(const c in this.fcol){
        const autorises=this.fcol[c];
        arr=arr.filter(s=>autorises.includes(this.valLisible(c,s)));
      }
      // Recherche globale
      if(this.recherche){
        const q=this.recherche.toLowerCase();
        arr=arr.filter(s=>JSON.stringify(s).toLowerCase().includes(q));
      }
      return arr;
    },
    agrandir(url){if(url)this.lightbox=url},
    formatDate(s){if(!s)return'';const p=s.split('-');return p.length===3?(p[2]+'/'+p[1]+'/'+p[0]):s},
    statutClasse(s){const v=(''+(s||'')).toLowerCase();if(v.includes('accept'))return'text-green-600';if(v.includes('rejet'))return'text-red-600';return'text-gray-600'},
    afficherToast(m){this.toast.message=m;if(this.toast.timer)clearTimeout(this.toast.timer);this.toast.timer=setTimeout(()=>{this.toast.message=''},3000)}
  };
}
</script>
</body></html>