{
  "name": "kyc-backend",
  "version": "4.0.0",
  "private": true,
  "description": "KYC Congo V4 – Backend TypeScript Fastify (MySQL)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child ./src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "create-admin": "ts-node ./src/scripts/create-admin.ts",
    "create-agent": "ts-node ./src/scripts/create-agent.ts",
    "create-superviseur": "ts-node ./src/scripts/create-superviseur.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.487.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "fastify-tsconfig": "^3.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae"
}
