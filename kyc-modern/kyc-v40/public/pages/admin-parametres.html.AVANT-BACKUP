<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - ⚙️ Paramètres</title><script src="https://cdn.tailwindcss.com"></script><script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
<style>
body{font-family:Inter,system-ui,sans-serif}
.sidebar{background:linear-gradient(180deg,#3f0808 0%,#7f1d1d 100%)}
.sb-link{display:flex;align-items:center;padding:.625rem .75rem;border-radius:.5rem;color:#d1d5db;transition:background .15s,color .15s;text-decoration:none}
.sb-link:hover{background:#7f1d1d;color:#fff}
.sb-link.active{background:#dc2626;color:#fff;font-weight:600}
</style>
<script>
async function chargerSidebarAdm(m){
  const t=sessionStorage.getItem('kyc_token');
  if(!t){window.location.href='/login';return}
  const u=JSON.parse(sessionStorage.getItem('kyc_user')||'{}');
  if(u.role!=='admin'){window.location.href='/sup/dashboard';return}
  const r=await fetch('/static/pages/_sidebar-admin.html');
  document.getElementById('sidebar-mount').innerHTML=await r.text();
  try{
    document.getElementById('sb-avatar').textContent=(u.matricule||'??').substring(0,2);
    document.getElementById('sb-nom').textContent=u.prenom||u.matricule||'';
    document.getElementById('sb-matricule').textContent=u.matricule||'';
    document.getElementById('sb-role').textContent=u.role||'';
  }catch(e){}
  if(m){const e=document.querySelector('[data-menu="'+m+'"]');if(e)e.classList.add('active')}
}
async function seDeconnecterGlobal(){
  const t=sessionStorage.getItem('kyc_token');
  if(t){try{await fetch('/api/auth/logout',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}}
  sessionStorage.clear();window.location.href='/login';
}
</script>
</head><body class="bg-gray-50 min-h-screen"><div class="flex min-h-screen"><div id="sidebar-mount"></div>
<main class="flex-1 min-w-0 p-6" x-data="params()" x-init="init()">

<div class="mb-5 border-b border-gray-200 pb-3"><h1 class="text-2xl font-bold text-gray-800">⚙️ Paramètres</h1><p class="text-gray-500 text-sm">Configuration système et paramètres globaux</p></div>

<!-- Seuil d'alerte file d'attente -->
<div class="bg-white rounded-xl border border-gray-200 p-6 max-w-xl">
<h2 class="font-bold text-gray-800 mb-1">⏱ Alerte file d'attente</h2>
<p class="text-sm text-gray-500 mb-4">Durée au-delà de laquelle un dossier en attente déclenche l'alerte rouge (sur les écrans agent, superviseur et admin).</p>
<div class="flex items-end gap-3">
<div>
<label class="block text-xs font-semibold text-gray-500 mb-1">Seuil d'alerte (minutes)</label>
<input type="number" min="1" max="1440" x-model.number="seuil" class="w-40 px-3 py-2 border border-gray-300 rounded-lg">
</div>
<button @click="enregistrer()" :disabled="loading" class="px-5 py-2 bg-red-600 hover:bg-red-700 disabled:bg-gray-300 text-white font-semibold rounded-lg">💾 Enregistrer</button>
</div>
<p x-show="msg" class="mt-3 text-sm" :class="msgType==='ok'?'text-green-600':'text-red-600'" x-text="msg"></p>
</div>

</main></div>
<script>
function params(){
  return {
    seuil:5,
    loading:false,
    msg:'',
    msgType:'ok',
    async init(){
      await chargerSidebarAdm('parametres');
      const t=sessionStorage.getItem('kyc_token');
      try{const r=await fetch('/api/config/seuil-alerte',{headers:{'Authorization':'Bearer '+t}});if(r.ok){const d=await r.json();this.seuil=d.seuil}}catch(e){}
    },
    async enregistrer(){
      this.msg='';this.loading=true;
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/config/seuil-alerte',{method:'PUT',headers:{'Authorization':'Bearer '+t,'Content-Type':'application/json'},body:JSON.stringify({seuil:this.seuil})});
        const d=await r.json();
        if(r.ok){this.seuil=d.seuil;this.msg='✅ Seuil enregistré ('+d.seuil+' min)';this.msgType='ok'}
        else{this.msg=d.error||'Erreur';this.msgType='err'}
      }catch(e){this.msg='Erreur réseau';this.msgType='err'}finally{this.loading=false}
    }
  };
}
</script>
</body></html>