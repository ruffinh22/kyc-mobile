<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>KYC BO - Reporting</title><script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
body{font-family:Inter,system-ui,sans-serif}
.sidebar{background:linear-gradient(180deg,#0c1e3e 0%,#1e3a5f 100%)}
.sb-link{display:flex;align-items:center;padding:.625rem .75rem;border-radius:.5rem;color:#cbd5e1;transition:background .15s,color .15s;text-decoration:none}
.sb-link:hover{background:#1e293b;color:#fff}
.sb-link.active{background:#3b82f6;color:#fff;font-weight:600}
.rcard{border-radius:12px;padding:16px}
.rbtn{display:block;width:100%;text-align:center;padding:10px;border-radius:8px;font-weight:700;font-size:13px;color:#fff;cursor:pointer;border:none;margin-top:10px}
.qbtn{padding:6px 12px;border:1px solid #d1d5db;border-radius:7px;background:#fff;font-size:12px;font-weight:600;color:#374151;cursor:pointer}
.qbtn:hover{background:#f3f4f6}
</style>
<script>
async function chargerSidebarSup(m){
  const t=sessionStorage.getItem('kyc_token');
  if(!t){window.location.href='/login';return}
  const u=JSON.parse(sessionStorage.getItem('kyc_user')||'{}');
  if(u.role!=='superviseur'&&u.role!=='admin'){window.location.href='/agent/dashboard';return}
  const r=await fetch('/static/pages/_sidebar-sup.html');
  document.getElementById('sidebar-mount').innerHTML=await r.text();
  try{
    document.getElementById('sb-avatar').textContent=(u.matricule||'??').substring(0,2);
    document.getElementById('sb-nom').textContent=u.prenom||u.matricule||'';
    document.getElementById('sb-matricule').textContent=u.matricule||'';
    document.getElementById('sb-role').textContent=u.role||'';
  }catch(e){}
  if(m){const e=document.querySelector('[data-menu="'+m+'"]');if(e)e.classList.add('active')}
}
async function seDeconnecterGlobal(){
  const t=sessionStorage.getItem('kyc_token');
  if(t){try{await fetch('/api/auth/logout',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}}
  sessionStorage.clear();window.location.href='/login';
}
</script>
</head><body style="background:#f3f4f6;min-height:100vh;margin:0"><div style="display:flex;min-height:100vh"><div id="sidebar-mount"></div>
<main style="flex:1;min-width:0;padding:28px">

<div style="display:flex;align-items:center;gap:14px;margin-bottom:22px">
<div style="width:50px;height:50px;border-radius:14px;background:#1f2937;color:#fff;display:flex;align-items:center;justify-content:center;font-size:24px">📊</div>
<div><h1 style="font-size:24px;font-weight:800;color:#1f2937;margin:0">Reporting</h1><p style="color:#9ca3af;font-size:14px;margin:2px 0 0">Export des données sur une période</p></div>
</div>

<div style="background:#fff;border:1px solid #e8e8ec;border-radius:16px;padding:22px;margin-bottom:24px;box-shadow:0 1px 3px rgba(0,0,0,.04)">
<p style="font-size:12px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px">📅 Période d'export</p>
<div style="display:flex;flex-wrap:wrap;gap:18px;align-items:flex-end">
<div><label style="display:block;font-size:12px;font-weight:600;color:#6b7280;margin-bottom:5px">Du *</label><input type="date" id="rep-date-debut" onchange="repMajLabel()" style="padding:9px 12px;border:1px solid #d1d5db;border-radius:10px;font-size:14px"></div>
<div><label style="display:block;font-size:12px;font-weight:600;color:#6b7280;margin-bottom:5px">Au *</label><input type="date" id="rep-date-fin" onchange="repMajLabel()" style="padding:9px 12px;border:1px solid #d1d5db;border-radius:10px;font-size:14px"></div>
<div style="display:flex;gap:8px">
<button onclick="setRepPeriode('today')" style="padding:8px 14px;border:1px solid #d1d5db;border-radius:9px;background:#fff;font-size:13px;font-weight:600;color:#374151;cursor:pointer">Aujourd'hui</button>
<button onclick="setRepPeriode('week')" style="padding:8px 14px;border:1px solid #d1d5db;border-radius:9px;background:#fff;font-size:13px;font-weight:600;color:#374151;cursor:pointer">Cette semaine</button>
<button onclick="setRepPeriode('month')" style="padding:8px 14px;border:1px solid #d1d5db;border-radius:9px;background:#fff;font-size:13px;font-weight:600;color:#374151;cursor:pointer">Ce mois</button>
