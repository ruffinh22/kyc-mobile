</div>


<div class="grid grid-cols-2 gap-2"><button @click="accepter(d.id)" :disabled="actionEnCours" style="background:#22c55e;color:#fff;font-weight:600;padding:10px;border-radius:8px;border:none;cursor:pointer;font-size:13px">&#10003; Accepter</button><button @click="ouvrirRejet(d)" :disabled="actionEnCours" style="background:#ef4444;color:#fff;font-weight:600;padding:10px;border-radius:8px;border:none;cursor:pointer;font-size:13px">&#10005; Rejeter</button></div>
</div></template>
