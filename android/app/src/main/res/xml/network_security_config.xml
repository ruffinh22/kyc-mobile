<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Autoriser cleartext HTTP pour développement/test local -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">10.208.9.116</domain>
    <domain includeSubdomains="true">10.58.134.116</domain>
    <domain includeSubdomains="true">10.0.5.38</domain>
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="true">127.0.0.1</domain>
  </domain-config>
  
  <!-- Production: HTTPS avec certificat Let's Encrypt -->
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="true">kyc.palladiumafrica.com</domain>
    <domain includeSubdomains="true">www.kyc.palladiumafrica.com</domain>
    <!-- Utiliser le certificat racine Let's Encrypt (ISRG Root X1) -->
    <trust-anchors>
      <certificates src="system" />
      <certificates src="@raw/lets_encrypt_root" />
    </trust-anchors>
  </domain-config>
</network-security-config>
