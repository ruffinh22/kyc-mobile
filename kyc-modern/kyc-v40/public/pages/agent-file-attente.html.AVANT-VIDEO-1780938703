</div></div>
</div>
<div x-show="modalRejet.ouvert" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"><div class="bg-white rounded-2xl p-6 max-w-md w-full"><h3 class="text-xl font-bold mb-4">❌ Rejeter</h3><p class="text-sm text-gray-600 mb-2">Numéro: <strong x-text="modalRejet.numero"></strong></p><label class="block text-sm font-semibold mt-4 mb-2">Motif *</label><textarea x-model="modalRejet.raison" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg"></textarea><div class="flex gap-2 mt-6"><button @click="fermerRejet()" class="flex-1 py-2 border border-gray-300 rounded-lg">Annuler</button><button @click="confirmerRejet()" :disabled="!modalRejet.raison||modalRejet.raison.length<3" class="flex-1 py-2 bg-red-500 hover:bg-red-600 disabled:bg-gray-300 text-white font-semibold rounded-lg">Confirmer</button></div></div></div>
<div x-show="modalAccept.ouvert" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"><div class="bg-white rounded-2xl p-6 max-w-md w-full"><h3 class="text-xl font-bold mb-4">✅ Accepter</h3><p class="text-sm text-gray-600 mb-2">Numéro: <strong x-text="modalAccept.numero"></strong></p><p class="text-sm text-gray-600 mt-2">Confirmer l'acceptation de ce dossier ?</p><div class="flex gap-2 mt-6"><button @click="fermerAccept()" class="flex-1 py-2 border border-gray-300 rounded-lg">Annuler</button><button @click="confirmerAccept()" class="flex-1 py-2 bg-green-500 hover:bg-green-600 disabled:bg-gray-300 text-white font-semibold rounded-lg">Confirmer</button></div></div></div>
<div x-show="modalPause.ouvert" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"><div class="bg-white rounded-2xl p-6 max-w-md w-full"><h3 class="text-xl font-bold mb-4">⏸️ Passer en pause</h3><p class="text-sm text-gray-600 mt-2">Vos dossiers en cours vont repartir dans la file. Confirmer la pause ?</p><div class="flex gap-2 mt-6"><button @click="modalPause.ouvert=false" class="flex-1 py-2 border border-gray-300 rounded-lg">Annuler</button><button @click="confirmerPause()" class="flex-1 py-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold rounded-lg">Confirmer</button></div></div></div>
<div x-show="modalBloc.ouvert" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"><div class="bg-white rounded-2xl p-6 max-w-md w-full"><div style="display:flex;align-items:center;gap:10px;margin-bottom:12px"><div style="width:42px;height:42px;border-radius:12px;background:#fef3c7;display:flex;align-items:center;justify-content:center;font-size:22px">&#9888;</div><h3 class="text-xl font-bold" x-text="modalBloc.titre"></h3></div><p class="text-sm text-gray-600" x-text="modalBloc.message"></p><div class="flex gap-2 mt-6"><button @click="modalBloc.ouvert=false" class="flex-1 py-2 bg-blue-700 hover:bg-blue-800 text-white font-semibold rounded-lg">Compris</button></div></div></div>
<!-- Lightbox capture -->
<div x-show="lightbox" @click="lightbox=''" class="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50 p-4 cursor-zoom-out"><img :src="lightbox" class="max-h-full max-w-full rounded-lg shadow-2xl"></div>
<div x-show="toast.message" class="fixed bottom-4 right-4 px-6 py-3 rounded-lg shadow-lg text-white font-semibold z-50" :class="toast.type==='success'?'bg-green-500':'bg-red-500'"><span x-text="toast.message"></span></div>
<div x-show="enPause" class="fixed inset-0 z-[100] flex flex-col items-center justify-center" style="display:none;background:#fdf6d8;padding:24px">
  <div style="font-size:56px;font-weight:800;color:#2563eb;letter-spacing:4px;line-height:1;margin-bottom:8px">&#10073;&#10073;</div>
  <h1 style="font-size:38px;font-weight:800;margin:0 0 4px;color:#ea580c">Vous êtes en pause</h1>
  <p style="font-size:18px;color:#475569;margin:0 0 32px" x-text="user.prenom?(user.prenom+' '+(user.nom||'')):(user.matricule||'')"></p>
  <div style="background:#fff;border-radius:18px;padding:24px 56px;text-align:center;box-shadow:0 2px 10px rgba(0,0,0,.05);margin-bottom:18px">
    <p style="font-size:13px;text-transform:uppercase;letter-spacing:.1em;color:#94a3b8;margin:0">Duree de la pause</p>
    <p style="font-size:60px;font-family:monospace;font-weight:700;margin:8px 0 4px;color:#0f172a" x-text="chronoPause"></p>
    <p style="font-size:14px;color:#94a3b8;margin:0">Depuis <span x-text="heurePause()"></span></p>
  </div>
  <div style="display:flex;gap:14px;margin-bottom:32px">
    <div style="background:#fff;border-radius:14px;padding:16px 32px;text-align:center;box-shadow:0 2px 10px rgba(0,0,0,.05)"><p style="font-size:14px;color:#94a3b8;margin:0">Pauses</p><p style="font-size:26px;font-weight:700;margin:2px 0 0;color:#0f172a" x-text="resumePauses.nb"></p></div>
    <div style="background:#fff;border-radius:14px;padding:16px 32px;text-align:center;box-shadow:0 2px 10px rgba(0,0,0,.05)"><p style="font-size:14px;color:#94a3b8;margin:0">Temps total</p><p style="font-size:26px;font-weight:700;margin:2px 0 0;color:#0f172a" x-text="resumePauses.total"></p></div>
  </div>
  <button @click="togglePause()" style="background:#16a34a;color:#fff;border:none;padding:18px 56px;border-radius:14px;font-size:20px;font-weight:700;cursor:pointer">&#9654; Reprendre le travail</button>
  <p style="font-size:14px;color:#94a3b8;font-style:italic;margin-top:20px">Votre superviseur voit que vous êtes en pause</p>
</div>
</main></div>
<script>
function fileAttente(){
  return {
    copier(txt){
      txt=String(txt||'');
      const ok=()=>{ this.afficherToast('Copie : '+txt); };
      if(navigator.clipboard && window.isSecureContext){
        navigator.clipboard.writeText(txt).then(ok).catch(()=>this._copieFallback(txt,ok));
      } else { this._copieFallback(txt,ok); }
    },
    _copieFallback(txt,ok){
      try{ const ta=document.createElement('textarea'); ta.value=txt;
        ta.style.position='fixed'; ta.style.top='-1000px'; ta.style.opacity='0';
        document.body.appendChild(ta); ta.focus(); ta.select();
        const r=document.execCommand('copy'); document.body.removeChild(ta);
        if(r){ ok&&ok(); } else { this.afficherToast('Copie impossible','error'); }
      }catch(e){ console.error('copie echec',e); this.afficherToast('Copie impossible','error'); }
    },
    user:{},
    stats:{total:0,en_attente:0,en_cours:0,accepte:0,rejete:0},
    enAttente:[],
    distributionMode:'manuel',
    enPause:false,
    chronoPause:'00:00',
    chronoTimer:null,
    pauseDebut:null,
    resumePauses:{nb:0,total:'0 min'},
    enCours:[],
    tousDossiers:[],
    photosUrls:{},
    lightbox:'',
    loading:false,
    actionEnCours:false,
    derniereMaj:'',
    dossiersAttenteVieux:0,
    modalRejet:{ouvert:false,id:null,numero:'',raison:''},
    modalAccept:{ouvert:false,id:null,numero:''},
    modalPause:{ouvert:false},
    modalBloc:{ouvert:false,titre:'',message:''},
    toast:{message:'',type:'success',timer:null},
    pollingTimer:null,
    async init(){
      window.addEventListener('bloc-deconnexion',()=>{ this.modalBloc={ouvert:true,titre:'Dossier en cours',message:'Vous avez un dossier en cours. Traitez-le (accepter ou rejeter) avant de vous deconnecter.'}; });
      await chargerSidebar('file-attente');
      try{const t=sessionStorage.getItem('kyc_token');const rm=await fetch('/api/config/distribution-mode',{headers:{'Authorization':'Bearer '+t}});if(rm.ok){const dm=await rm.json();this.distributionMode=dm.mode||'manuel'}}catch(e){console.error('mode',e)}
      try{this.user=JSON.parse(sessionStorage.getItem('kyc_user')||'{}')}catch(e){}
      await this.restaurerEtatPause();
      await this.charger();
      this.pollingTimer=setInterval(()=>this.charger(true),15000);
      this.pingDispo();
      this.pingTimer=setInterval(()=>this.pingDispo(),10000);
      this.demarrerFlux();
    },
    async charger(silencieux){
      if(!silencieux)this.loading=true;
      const t=sessionStorage.getItem('kyc_token');
      const d=new Date().toISOString().slice(0,10);
      try{
        const r1=await fetch('/api/dossiers/stats?date='+d,{headers:{'Authorization':'Bearer '+t}});
        if(r1.status===401){window.location.href='/login';return}
        this.stats=await r1.json();
        const r2=await fetch('/api/dossiers',{headers:{'Authorization':'Bearer '+t}});
        const dat=await r2.json();
        const tous=dat.dossiers||[];
        this.tousDossiers=tous;
        // Accepte/Rejete INDIVIDUELS : compter uniquement les dossiers de cet agent
        try{
          const moi=this.user.matricule;
          const auj=new Date().toISOString().slice(0,10);
          this.stats.accepte=tous.filter(x=>x.statut==='accepte'&&x.agent_saisie===moi&&x.date===auj).length;
          this.stats.rejete=tous.filter(x=>x.statut==='rejete'&&x.agent_saisie===moi&&x.date===auj).length;
          // En cours PERSONNEL : ses dossiers en cours
          this.stats.en_cours=tous.filter(x=>x.statut==='en_cours'&&x.agent_saisie===moi).length;
          // Total PERSONNEL du jour : en cours + acceptes + rejetes (de cet agent, aujourd'hui)
          this.stats.total=this.stats.en_cours+this.stats.accepte+this.stats.rejete;
        }catch(e){}
        this.enAttente=tous.filter(d=>d.statut==='en_attente').sort((a,b)=>a.created_at-b.created_at);
        this.enCours=tous.filter(d=>d.statut==='en_cours'&&d.agent_saisie===this.user.matricule);
        this.dossiersAttenteVieux=this.enAttente.filter(d=>this.dureeMinutes(d.created_at)>5).length;
        this.derniereMaj=new Date().toLocaleTimeString('fr-FR');
        await this.chargerPhotosEnCours();
      }catch(e){console.error(e)}finally{this.loading=false}
    },
    async chargerPhotosEnCours(){
      const t=sessionStorage.getItem('kyc_token');
      const nouveaux={};
      for(const d of this.enCours){
        // Si on a déjà chargé les photos de ce dossier, on les réutilise (évite de recharger à chaque polling)
        if(this.photosUrls[d.id]){nouveaux[d.id]=this.photosUrls[d.id];continue}
        const p={recto:null,verso:null,live:null};
        for(const type of ['recto','verso','live']){
          try{
            const r=await fetch('/api/dossiers/'+d.id+'/photo/'+type,{headers:{'Authorization':'Bearer '+t}});
            if(r.ok){const b=await r.blob();p[type]=URL.createObjectURL(b)}
          }catch(e){}
        }
        nouveaux[d.id]=p;
      }
      // Libère les URLs des dossiers qui ne sont plus en cours
      for(const id in this.photosUrls){
        if(!nouveaux[id]){
          const p=this.photosUrls[id];
          ['recto','verso','live'].forEach(k=>{if(p&&p[k])URL.revokeObjectURL(p[k])});
        }
      }
      this.photosUrls=nouveaux;
    },
    agrandir(url){if(url)this.lightbox=url},
    tempsMoyenTraitement(){
      // Moyenne (en minutes) entre prise (assigne_le) et cloture (closed_at)
      // des dossiers traites aujourd'hui par cet agent.
      const traites=(this.tousDossiers||[]).filter(d=>
        (d.statut==='accepte'||d.statut==='rejete') &&
        d.agent_saisie===this.user.matricule &&
        d.assigne_le && d.closed_at && d.closed_at>=d.assigne_le
      );
      if(!traites.length) return 0;
      let total=0;
      for(const d of traites){ total += (d.closed_at - d.assigne_le); }
      return Math.round((total/traites.length)/60);
    },
    touchTimeMoyen(){
      // Moyenne (en minutes) du touch_time (distribution -> enregistrement GSM)
      // des dossiers traites aujourd'hui par cet agent.
      const auj=new Date().toISOString().slice(0,10);
      const avecTT=(this.tousDossiers||[]).filter(d=>
        d.agent_saisie===this.user.matricule &&
        d.date===auj &&
        d.touch_time!=null && d.touch_time>=0
      );
      if(!avecTT.length) return 0;
      let total=0;
      for(const d of avecTT){ total += d.touch_time; }
      return Math.round((total/avecTT.length)/60);
    },
    dureeMinutes(ts){return Math.floor((Math.floor(Date.now()/1000)-ts)/60)},
    demarrerFlux(){
      const t=sessionStorage.getItem('kyc_token');
      if(!t)return;
      try{
        if(this.flux){this.flux.close()}
        this.flux=new EventSource('/api/dossiers/flux?token='+encodeURIComponent(t));
        this.flux.addEventListener('nouveau-dossier',()=>{ this.charger(true); });
        this.flux.onerror=()=>{ /* reconnexion auto par le navigateur */ };
      }catch(e){console.error('flux SSE',e)}
    },
    fmtDuree(sec){const m=Math.floor(sec/60),s2=sec%60;return String(m).padStart(2,'0')+':'+String(s2).padStart(2,'0')},
    async chargerResumePauses(majPauseDebut){
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/pauses-jour',{headers:{'Authorization':'Bearer '+t}});
        if(r.ok){const d=await r.json();this.resumePauses={nb:d.nb_pauses,total:Math.round(d.duree_totale_sec/60)+' min'};if(majPauseDebut&&d.pause_debut)this.pauseDebut=d.pause_debut}
      }catch(e){}
    },
    heurePause(){
      if(!this.pauseDebut) return (this.user && this.user.pause_depuis) ? this.user.pause_depuis : '';
      const d=new Date(this.pauseDebut*1000);
      return String(d.getHours()).padStart(2,'0')+'h'+String(d.getMinutes()).padStart(2,'0');
    },
    demarrerChrono(){
      if(this.chronoTimer)clearInterval(this.chronoTimer);
      const maj=()=>{ if(!this.pauseDebut){this.chronoPause='00:00';return} const ecoule=Math.floor(Date.now()/1000)-this.pauseDebut; this.chronoPause=this.fmtDuree(ecoule); };
      maj();
      this.chronoTimer=setInterval(maj,1000);
    },
    async demanderAide(){
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/aide',{method:'POST',headers:{'Authorization':'Bearer '+t}});
        if(r.ok){this.afficherToast('Demande d\'aide envoyee au superviseur','success')}
        else{this.afficherToast('Erreur lors de l\'envoi','error')}
      }catch(e){this.afficherToast('Erreur reseau','error')}
    },
    async restaurerEtatPause(){
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/pauses-jour',{headers:{'Authorization':'Bearer '+t}});
        if(r.ok){
          const d=await r.json();
          if(d.en_pause){
            this.enPause=true;
            this.pauseDebut=d.pause_debut||Math.floor(Date.now()/1000);
            this.resumePauses={nb:d.nb_pauses,total:Math.round(d.duree_totale_sec/60)+' min'};
            this.demarrerChrono();
          }
        }
      }catch(e){}
    },
    async togglePause(){
      // Si deja en pause -> reprendre directement
      if(this.enPause){ await this.confirmerPause(); return; }
      // Pas en pause : si un dossier est en cours -> pause PROGRAMMEE (apres saisie Gross Add)
      if(this.enCours.length>0){
        try{ sessionStorage.setItem('pause_apres_gross','1'); }catch(e){}
        this.afficherToast('⏸️ Pause programmee : elle demarrera apres votre saisie Gross Add','success');
        return;
      }
      // Pas en pause et aucun dossier en cours -> pause directe (sans pop-up)
      await this.confirmerPause();
    },
    async confirmerPause(){
      this.modalPause.ouvert=false;
      const t=sessionStorage.getItem('kyc_token');
      const action=this.enPause?'reprendre':'pause';
      try{
        const r=await fetch('/api/dossiers/pause',{method:'POST',headers:{'Authorization':'Bearer '+t,'Content-Type':'application/json'},body:JSON.stringify({action})});
        const d=await r.json().catch(()=>({}));
        if(r.ok){
          this.enPause=(d.statut==='pause');
          if(this.enPause){ this.pauseDebut=Math.floor(Date.now()/1000); await this.chargerResumePauses(false); this.demarrerChrono(); }
          else { if(this.chronoTimer){clearInterval(this.chronoTimer);this.chronoTimer=null} this.pauseDebut=null; }
          this.afficherToast(this.enPause?'En pause':'Vous avez repris','success');
          await this.charger();
        } else { this.afficherToast(d.error||'Erreur','error'); }
      }catch(e){this.afficherToast('Erreur reseau','error')}
    },
    async pingDispo(){
      const t=sessionStorage.getItem('kyc_token');
      try{await fetch('/api/dossiers/ping-dispo',{method:'POST',headers:{'Authorization':'Bearer '+t}})}catch(e){}
    },
    async appeler(){
      if(this.actionEnCours)return;
      this.actionEnCours=true;
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/appeler',{method:'POST',headers:{'Authorization':'Bearer '+t}});
        const d=await r.json().catch(()=>({}));
        if(r.ok&&d.aucun){this.afficherToast('Aucun dossier en attente','error')}
        else if(r.ok){this.afficherToast('Dossier attribue','success');await this.charger()}
        else{this.afficherToast(d.error||'Erreur','error')}
      }catch(e){this.afficherToast('Erreur reseau','error')}
      finally{this.actionEnCours=false}
    },
    async prendre(id){
      if(this.actionEnCours)return;
      this.actionEnCours=true;
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/'+id+'/prendre',{method:'POST',headers:{'Authorization':'Bearer '+t}});
        const dat=await r.json();
        if(r.ok){this.afficherToast('Dossier pris','success');await this.charger()}
        else{this.afficherToast(dat.error||'Erreur','error')}
      }catch(e){this.afficherToast('Erreur réseau','error')}finally{this.actionEnCours=false}
    },
    accepter(id){
      const dd=this.enCours.find(x=>x.id===id);
      this.modalAccept={ouvert:true,id:id,numero:dd?dd.numero_mtn:''};
    },
    fermerAccept(){this.modalAccept.ouvert=false;},
    async confirmerAccept(){
      const id=this.modalAccept.id;
      this.modalAccept.ouvert=false;
      if(this.actionEnCours)return;
      this.actionEnCours=true;
      const t=sessionStorage.getItem('kyc_token');
      try{
        const r=await fetch('/api/dossiers/'+id+'/accepter',{method:'POST',headers:{'Authorization':'Bearer '+t,'Content-Type':'application/json'},body:'{}'});
        const dat=await r.json();
        if(r.ok){const dd=this.enCours.find(x=>x.id===id);const num=dd?dd.numero_mtn:'';try{sessionStorage.setItem('gsm_a_finaliser',JSON.stringify({dossier:id,numero:num||''}))}catch(e){}this.afficherToast('✅ Accepté - GSM à remplir','success');setTimeout(()=>{window.location.href='/agent/gross-add?numero='+encodeURIComponent(num||'')+'&dossier='+encodeURIComponent(id)},800);return}
        else{this.afficherToast(dat.error||'Erreur','error')}
      }catch(e){this.afficherToast('Erreur réseau','error')}finally{this.actionEnCours=false}
    },
    ouvrirRejet(d){this.modalRejet={ouvert:true,id:d.id,numero:d.numero_mtn,raison:''}},
    fermerRejet(){this.modalRejet.ouvert=false},
    async confirmerRejet(){
      if(!this.modalRejet.raison||this.modalRejet.raison.length<3)return;
      this.actionEnCours=true;
      const t=sessionStorage.getItem('kyc_token');
      const id=this.modalRejet.id;
      try{
        const r=await fetch('/api/dossiers/'+id+'/rejeter',{method:'POST',headers:{'Authorization':'Bearer '+t,'Content-Type':'application/json'},body:JSON.stringify({raison_rejet:this.modalRejet.raison})});
        const dat=await r.json();
        if(r.ok){const num=this.modalRejet.numero;try{sessionStorage.setItem('gsm_a_finaliser',JSON.stringify({dossier:id,numero:num||''}))}catch(e){}this.afficherToast('❌ Rejeté - GSM à remplir','success');this.fermerRejet();setTimeout(()=>{window.location.href='/agent/gross-add?numero='+encodeURIComponent(num||'')+'&dossier='+encodeURIComponent(id)},800);return}
        else{this.afficherToast(dat.error||'Erreur','error')}
      }catch(e){this.afficherToast('Erreur','error')}finally{this.actionEnCours=false}
    },
    afficherToast(m,t){
      this.toast.message=m;this.toast.type=t||'success';
      if(this.toast.timer)clearTimeout(this.toast.timer);
      this.toast.timer=setTimeout(()=>{this.toast.message=''},3000);
    }
  };
}
</script>
</body></html>
